---
import fs from "node:fs";
import path from "node:path";
import { parseCsv } from "../lib/csvSimple";

type NavRow = {
  id: string;
  parent_id: string;
  level: number;
  label: string;
  href: string;
  visible: boolean;
  sort_order: number;
};

const csvPath = path.join(process.cwd(), "src", "data", "site_nav.csv");
const rows = parseCsv(fs.readFileSync(csvPath, "utf-8"))
  .map((r) => ({
    id: String(r.id ?? "").trim(),
    parent_id: String(r.parent_id ?? "").trim(),
    level: Number(r.level ?? 1) || 1,
    label: String(r.label ?? "").trim(),
    href: String(r.href ?? "").trim(),
    visible:
      String(r.visible ?? "")
        .trim()
        .toLowerCase() !== "false",
    sort_order: Number(r.sort_order ?? 9999) || 9999,
  }))
  .filter((r) => r.id && r.label && r.visible)
  .sort((a, b) => a.sort_order - b.sort_order) as NavRow[];

const currentPath = Astro.url.pathname;
const normalizePath = (value: string) => {
  const pathOnly =
    String(value || "/")
      .split("#")[0]
      .split("?")[0] || "/";
  if (pathOnly === "/") return "/";
  return pathOnly.endsWith("/") ? pathOnly.slice(0, -1) : pathOnly;
};

const current = normalizePath(currentPath);
const isActive = (href: string) => {
  const target = normalizePath(href);
  if (target === "/") return current === "/";
  return current === target || current.startsWith(`${target}/`);
};

const activeIds = new Set<string>();
for (const row of rows) {
  if (!row.href || !isActive(row.href)) continue;
  activeIds.add(row.id);
  let parentId = row.parent_id;
  while (parentId) {
    const parent = rows.find((r) => r.id === parentId);
    if (!parent) break;
    activeIds.add(parent.id);
    parentId = parent.parent_id;
  }
}
---

<aside class="side-nav" aria-label="サイト内ナビゲーション">
  <div class="side-nav__title">サイトマップ</div>
  <nav>
    <ul class="side-nav__list">
      {
        rows.map((item) => (
          <li class={`side-nav__item side-nav__item--lv${item.level}`}>
            <a
              href={item.href || "#"}
              class:list={[
                "side-nav__link",
                { "is-active": activeIds.has(item.id) },
              ]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<style>
  .side-nav {
    position: fixed;
    left: 16px;
    top: 96px;
    width: 260px;
    max-height: calc(100vh - 116px);
    overflow: auto;
    background: #fff;
    border: 1px solid var(--border, #e6e6e6);
    border-radius: 14px;
    padding: 12px 10px;
    font-size: 13px;
    z-index: 20;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .side-nav__title {
    font-weight: 800;
    font-size: 13px;
    margin: 0 0 8px;
    padding: 0 6px 8px;
    border-bottom: 1px solid var(--border, #e6e6e6);
  }

  .side-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .side-nav__item {
    margin: 1px 0;
  }

  .side-nav__item--lv1 {
    padding-left: 0;
  }
  .side-nav__item--lv2 {
    padding-left: 12px;
  }
  .side-nav__item--lv3 {
    padding-left: 24px;
  }
  .side-nav__item--lv4 {
    padding-left: 36px;
  }

  .side-nav__link {
    display: block;
    color: #333;
    text-decoration: none;
    line-height: 1.35;
    padding: 5px 7px;
    border-radius: 8px;
    border-left: 3px solid transparent;
  }

  .side-nav__link:hover {
    background: #f7f7f7;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .side-nav__link.is-active {
    font-weight: 800;
    color: var(--theme-color, #111);
    background: color-mix(in srgb, var(--theme-color, #111) 8%, #ffffff);
    border-left-color: var(--theme-color, #111);
  }

  .side-nav__item--lv1 > .side-nav__link {
    font-weight: 800;
  }

  @media (max-width: 1500px) {
    .side-nav {
      display: none;
    }
  }
</style>
