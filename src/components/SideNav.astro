---
import fs from "node:fs";
import path from "node:path";
import { parseCsv } from "../lib/csvSimple";

type NavRow = {
  id: string;
  parent_id: string;
  level: number;
  label: string;
  href: string;
  visible: boolean;
  sort_order: number;
};

const csvPath = path.join(process.cwd(), "src", "data", "site_nav.csv");
const rows = parseCsv(fs.readFileSync(csvPath, "utf-8"))
  .map((r) => ({
    id: String(r.id ?? "").trim(),
    parent_id: String(r.parent_id ?? "").trim(),
    level: Number(r.level ?? 1) || 1,
    label: String(r.label ?? "").trim(),
    href: String(r.href ?? "").trim(),
    visible:
      String(r.visible ?? "")
        .trim()
        .toLowerCase() !== "false",
    sort_order: Number(r.sort_order ?? 9999) || 9999,
  }))
  .filter((r) => r.id && r.label && r.visible)
  .sort((a, b) => a.sort_order - b.sort_order) as NavRow[];

const currentPath = Astro.url.pathname;
const normalizePath = (value: string) => {
  const pathOnly =
    String(value || "/")
      .split("#")[0]
      .split("?")[0] || "/";
  if (pathOnly === "/") return "/";
  return pathOnly.endsWith("/") ? pathOnly.slice(0, -1) : pathOnly;
};

const current = normalizePath(currentPath);
const isActive = (href: string) => {
  const target = normalizePath(href);
  if (target === "/") return current === "/";
  return current === target || current.startsWith(`${target}/`);
};

const activeIds = new Set<string>();
for (const row of rows) {
  if (!row.href || !isActive(row.href)) continue;
  activeIds.add(row.id);
  let parentId = row.parent_id;
  while (parentId) {
    const parent = rows.find((r) => r.id === parentId);
    if (!parent) break;
    activeIds.add(parent.id);
    parentId = parent.parent_id;
  }
}
---

<button
  class="side-nav-toggle"
  type="button"
  aria-controls="side-nav"
  aria-expanded="false"
>
  ☰ サイトマップ
</button>

<div class="side-nav-backdrop" hidden></div>

<aside id="side-nav" class="side-nav" aria-label="サイト内ナビゲーション">
  <div class="side-nav__head">
    <div class="side-nav__title">サイトマップ</div>
    <button
      class="side-nav__close"
      type="button"
      aria-label="サイトマップを閉じる">×</button
    >
  </div>

  <nav>
    <ul class="side-nav__list">
      {
        rows.map((item) => (
          <li class={`side-nav__item side-nav__item--lv${item.level}`}>
            <a
              href={item.href || "#"}
              class:list={[
                "side-nav__link",
                { "is-active": activeIds.has(item.id) },
              ]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<style>
  .side-nav {
    position: fixed;
    left: 16px;
    top: 96px;
    width: 260px;
    max-height: calc(100vh - 116px);
    overflow: auto;
    background: #fff;
    border: 1px solid var(--border, #e6e6e6);
    border-radius: 14px;
    padding: 12px 10px;
    font-size: 13px;
    z-index: 20;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .side-nav__title {
    font-weight: 800;
    font-size: 13px;
    margin: 0 0 8px;
    padding: 0 6px 8px;
    border-bottom: 1px solid var(--border, #e6e6e6);
  }

  .side-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .side-nav__item {
    margin: 1px 0;
  }

  .side-nav__item--lv1 {
    padding-left: 0;
  }
  .side-nav__item--lv2 {
    padding-left: 12px;
  }
  .side-nav__item--lv3 {
    padding-left: 24px;
  }
  .side-nav__item--lv4 {
    padding-left: 36px;
  }

  .side-nav__link {
    display: block;
    color: #333;
    text-decoration: none;
    line-height: 1.35;
    padding: 5px 7px;
    border-radius: 8px;
    border-left: 3px solid transparent;
  }

  .side-nav__link:hover {
    background: #f7f7f7;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .side-nav__link.is-active {
    font-weight: 800;
    color: var(--theme-color, #111);
    background: color-mix(in srgb, var(--theme-color, #111) 8%, #ffffff);
    border-left-color: var(--theme-color, #111);
  }

  .side-nav__item--lv1 > .side-nav__link {
    font-weight: 800;
  }

  .side-nav-toggle {
    position: fixed;
    left: 12px;
    top: 96px;
    z-index: 35;
    display: none;
    border: 1px solid var(--border, #e6e6e6);
    border-radius: 999px;
    background: #fff;
    padding: 7px 11px;
    font-size: 12px;
    font-weight: 800;
    color: #333;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    cursor: pointer;
  }

  .side-nav-backdrop {
    position: fixed;
    inset: 0;
    z-index: 30;
    background: rgba(0, 0, 0, 0.28);
  }

  .side-nav__head {
    position: sticky;
    top: 0;
    z-index: 2;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin: 0 -12px 8px;
    padding: 10px 12px;
    border-bottom: 1px solid var(--border, #e6e6e6);
  }

  .side-nav__title {
    font-weight: 800;
    font-size: 13px;
    margin: 0;
    padding: 0;
    border-bottom: 0;
  }

  .side-nav__close {
    display: none;
    width: 32px;
    height: 32px;
    border: 1px solid var(--border, #e6e6e6);
    border-radius: 999px;
    background: #fff;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    font-weight: 700;
  }

  @media (max-width: 1700px) {
    .side-nav {
      top: 188px;
      height: calc(100vh - 220px);
      max-height: calc(100vh - 220px);
      padding: 0 10px 12px;
      font-size: 12px;
      width: min(300px, calc(100vw - 28px));
      left: 14px;
      border-radius: 14px;
      transform: translateX(calc(-100% - 24px));
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    .side-nav.is-open {
      transform: translateX(0);
    }

    .side-nav-toggle {
      display: inline-flex;
      align-items: center;
      gap: 2px;
      top: 90px;
      left: 16px;
    }

    .side-nav__close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .side-nav-toggle {
      top: 186px;
      left: 8px;
      font-size: 10px;
      padding: 3px 8px;
      z-index: 45;
      line-height: 1.1;
      border-radius: 999px;
      width: auto;
      min-width: 0;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
      background: rgba(255, 247, 204, 0.88);
      border-color: #e0c15a;
      color: #111;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);

      backdrop-filter: blur(2px);
    }

    .side-nav {
      top: 192px;
      left: 8px;
      width: min(260px, 70vw);
      height: calc(100vh - 224px);
      max-height: calc(100vh - 224px);
      padding: 0 10px 12px;
      font-size: 12px;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      z-index: 40;
      overflow-x: hidden;
    }

    .side-nav__head {
      margin: 0 -10px 6px;
      padding: 8px 10px;
    }

    .side-nav__title {
      font-size: 12px;
    }

    .side-nav__close {
      width: 28px;
      height: 28px;
      font-size: 16px;
    }

    .side-nav__link {
      padding: 4px 6px;
      line-height: 1.28;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .side-nav__item--lv2 {
      padding-left: 8px;
    }
    .side-nav__item--lv3 {
      padding-left: 16px;
    }
    .side-nav__item--lv4 {
      padding-left: 24px;
    }
  }
</style>

<script>
  const toggle = document.querySelector(".side-nav-toggle");
  const nav = document.querySelector(".side-nav");
  const close = document.querySelector(".side-nav__close");
  const backdrop = document.querySelector(".side-nav-backdrop");

  const openNav = () => {
    nav?.classList.add("is-open");
    backdrop?.removeAttribute("hidden");
    toggle?.setAttribute("aria-expanded", "true");
    document.body.classList.add("is-side-nav-open");
  };

  const closeNav = () => {
    nav?.classList.remove("is-open");
    backdrop?.setAttribute("hidden", "");
    toggle?.setAttribute("aria-expanded", "false");
    document.body.classList.remove("is-side-nav-open");
  };

  toggle?.addEventListener("click", openNav);
  close?.addEventListener("click", closeNav);
  backdrop?.addEventListener("click", closeNav);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeNav();
  });

  nav?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", closeNav);
  });
</script>
