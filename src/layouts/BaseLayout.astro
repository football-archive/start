---
import TitleBar from "../components/TitleBar.astro";
import SiteHeader from "../components/SiteHeader.astro";

type Crumb = { label: string; href?: string };

type Props = {
  title: string;
  description?: string;
  bodyStyle?: string;
  bodyClass?: string;
  showPageHeader?: boolean;
  crumbs?: Crumb[];
  heading?: string;
  showTitleBarPageTitle?: boolean;
};

const {
  title,
  description,
  bodyStyle = "margin:0; font-family: system-ui;",
  bodyClass = "",
  showPageHeader = false,
  crumbs = [],
  heading,
  showTitleBarPageTitle = true,
} = Astro.props as Props;

const hasUnderTitle = Astro.slots.has("under-title");

const siteNameBar = "World Football Archive｜海外サッカーDB";
const barPageTitle = showTitleBarPageTitle ? title : "";

// ✅ TitleBarが2段かどうか（padding出し分け用）
const hasBar2 = !!barPageTitle;

const siteNameSeo = "World Football Archive";
const seoTitle = title ? `${title}｜${siteNameSeo}` : siteNameSeo;

const metaDescription =
  description && String(description).trim() ? description : seoTitle;

/**
 * canonical は「クエリなし・末尾スラッシュあり」で統一
 * - /wc/2026/team/ブラジル  → /wc/2026/team/ブラジル/
 * - /                         → /
 * - /favicon.png など拡張子付きはそのまま
 */
const normalizeCanonicalPath = (pathname: string) => {
  const p = String(pathname || "").trim() || "/";

  // ルートはそのまま
  if (p === "/") return "/";

  // 拡張子つきファイルっぽいものはそのまま
  if (/\.[a-z0-9]+$/i.test(p)) return p;

  // 末尾スラッシュを付ける
  return p.endsWith("/") ? p : `${p}/`;
};

const canonicalPath = normalizeCanonicalPath(Astro.url.pathname);

const canonicalUrl = Astro.site
  ? new URL(canonicalPath, Astro.site).toString()
  : canonicalPath;

/**
 * OGP画像はできれば絶対URLが堅い（SNSクローラ対策）
 * Astro.site が無い場合は相対のまま
 */
const ogImage = Astro.site
  ? new URL("/ogp.png", Astro.site).toString()
  : "/ogp.png";

/**
 * JSON-LD: BreadcrumbList
 * crumbs が「label」だけ（href無し）で渡ってくる運用なので、
 * href があるものだけ item を持たせる。最後は現在ページとしてitem無しでもOK。
 */
const buildBreadcrumbJsonLd = () => {
  if (!crumbs || crumbs.length === 0) return "";

  const items = crumbs
    .filter((c) => c && String(c.label ?? "").trim())
    .map((c, idx) => {
      const label = String(c.label ?? "").trim();
      const href = String(c.href ?? "").trim();

      // href がない場合は「現在ページ」扱いで item を付けない
      const item =
        href && Astro.site ? new URL(href, Astro.site).toString() : href;

      const base: any = {
        "@type": "ListItem",
        position: idx + 1,
        name: label,
      };
      if (item) base.item = item;
      return base;
    });

  const json = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: items,
  };

  return JSON.stringify(json);
};

const breadcrumbJsonLd = buildBreadcrumbJsonLd();

/**
 * WebSite / Organization（最小構成）
 * ※将来ロゴやSNSが揃ったらここに追加していけばOK
 */
const websiteJsonLd = Astro.site
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: siteNameSeo,
      url: Astro.site.toString(),
    })
  : "";

const orgJsonLd = Astro.site
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: siteNameSeo,
      url: Astro.site.toString(),
    })
  : "";

// heading（既存）
const pageHeading = heading || title;
---

<!doctype html>
<html lang="ja">
  <head>
    <style is:global>
      :root {
        --container-max: 1100px;
        --container-pad: 16px;
        --border: #e6e6e6;
        --muted: #666;

        /* ===== Palette (司令塔) ===== */
        --color-ucl: #0a1f44; /* CL：紺 */
        --color-wc: #7a1f2b; /* WC：ワインレッド（暫定） */
        --color-japan: #1f4fa3; /* 日本：SAMURAI BLUE */
        --color-club: #2f855a; /* クラブ：仮グリーン（試験） */
        --color-awards: #c9a227; /* 表彰：金 */
        --color-euro: #6b7280; /* EURO：グレー仮置き */

        /* ★ default theme（未指定時の基準） */
        --theme-color: var(--color-euro);

        --color-club-accent: #2f855a; /* クラブ強調用（試験） */

        /* ===== Derived tokens ===== */
        --theme-link: var(--theme-color);
        --theme-soft-bg: color-mix(in srgb, var(--theme-color) 64%, #ffffff);
        --theme-soft-border: color-mix(
          in srgb,
          var(--theme-color) 82%,
          var(--border)
        );
      }

      body {
        --theme-table-head-bg: color-mix(
          in srgb,
          var(--theme-color) 38%,
          #ffffff
        );
        --theme-table-head-border: color-mix(
          in srgb,
          var(--theme-color) 55%,
          var(--border)
        );
        --theme-table-head-solid: color-mix(
          in srgb,
          var(--theme-color) 82%,
          #000000
        );
      }

      /* ===== Theme switch by page ===== */
      body.page-wc {
        --theme-color: var(--color-wc);
      }
      body.page-ucl {
        --theme-color: var(--color-ucl);
      }
      body.page-japan {
        --theme-color: var(--color-japan);
      }
      body.page-awards {
        --theme-color: var(--color-awards);
      }
      body.page-club {
        --theme-color: var(--color-club-accent);
      }
      body.page-euro {
        --theme-color: var(--color-euro);
      }

      /* ===== Theme switch by scope (home cards etc.) ===== */
      .theme-wc {
        --theme-color: var(--color-wc);
      }
      .theme-ucl {
        --theme-color: var(--color-ucl);
      }
      .theme-japan {
        --theme-color: var(--color-japan);
      }
      .theme-awards {
        --theme-color: var(--color-awards);
      }
      .theme-club {
        --theme-color: var(--color-club);
      }
      .theme-euro {
        --theme-color: var(--color-euro);
      }

      table thead th {
        background: var(--theme-table-head-bg);
        border-color: var(--theme-table-head-border);
      }

      body.page-ucl .pill.is-active {
        background: var(--theme-color);
        color: #fff;
        border-color: var(--theme-color);
      }

      .app-main {
        padding-top: 0;
      }

      .page-wrap {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: var(--container-pad);
      }

      .empty {
        margin-top: 16px;
        padding: 16px;
        border: 1px solid var(--border, #e6e6e6);
        border-radius: 12px;
        background: #fff;
      }
      .empty h2 {
        margin: 0 0 8px;
        font-size: 18px;
      }
      .empty p {
        margin: 0 0 12px;
        opacity: 0.8;
        line-height: 1.6;
      }
      .empty-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      .empty-actions .btn {
        display: inline-block;
        padding: 8px 12px;
        border: 1px solid var(--border, #e6e6e6);
        border-radius: 10px;
        text-decoration: none;
        color: inherit;
        background: #fff;
      }
      .empty-actions .btn:hover {
        background: #f7f7f7;
      }
      /* CLと日本だけ、もう一段濃くして“アイコン色”に寄せる */
      .subcard.theme-ucl,
      .subcard.theme-japan {
        --theme-soft-bg: color-mix(in srgb, var(--theme-color) 70%, #ffffff);
        --theme-soft-border: color-mix(
          in srgb,
          var(--theme-color) 88%,
          var(--border)
        );
        color: #fff;
        border-color: rgba(0, 0, 0, 0.25);
      }
      /* リンク色 */
      .subcard.theme-ucl a,
      .subcard.theme-japan a {
        color: #fff;
        text-decoration-color: rgba(255, 255, 255, 0.7);
      }

      .subcard.theme-ucl a:hover,
      .subcard.theme-japan a:hover {
        text-decoration-color: #fff;
      }

      /* 更新日など補助テキスト */
      .subcard.theme-ucl .ucl-sub,
      .subcard.theme-japan .jp-sub {
        color: rgba(255, 255, 255, 0.85);
      }

      /* トップの通常カード（右上クラブなど）も少し濃く */
      .card {
        --theme-soft-bg: color-mix(in srgb, var(--theme-color) 38%, #ffffff);
        --theme-soft-border: color-mix(
          in srgb,
          var(--theme-color) 62%,
          var(--border)
        );
      }

      .card h2 {
        font-size: 18px;
      }
      .subcard h2 {
        font-size: 18px;
      }

      .theme-japan,
      .theme-ucl {
        color: #fff;
      }

      .title-white {
        color: #fff;
      }
      /* ===== Anchor jump offset (for sticky TitleBar) ===== */
      body.has-titlebar-1 {
        --titlebar-offset: 4px; /* 1段タイトル */
      }
      body.has-titlebar-2 {
        --titlebar-offset: 22px; /* 2段タイトル */
      }

      /* ブラウザのアンカー移動 / scrollIntoView をまとめて補正 */
      html {
        scroll-padding-top: var(--titlebar-offset, 72px);
      }

      /* 念のため：id持ち要素側にも補正（見出し/sectionに効く） */
      :where(section[id], [id]) {
        scroll-margin-top: var(--titlebar-offset, 72px);
      }

      /* ===== UCLページ：紺をより濃く ===== */
      body.page-ucl {
        --theme-color: #071a3a; /* ← 少し深い紺 */
      }

      /* ヘッダー下の枠やカード背景をさらに引き締め */
      body.page-ucl .box,
      body.page-ucl .subcard,
      body.page-ucl .section {
        --theme-soft-bg: color-mix(in srgb, var(--theme-color) 16%, #ffffff);
        --theme-soft-border: color-mix(
          in srgb,
          var(--theme-color) 38%,
          var(--border)
        );
      }

      /* ===== Meta line (ct / nt) ===== */
      :where(.ct-meta, .nt-meta) {
        font-size: 20px !important;
        font-weight: 800;
        line-height: 1.35;
        letter-spacing: 0.02em;
        margin: 10px 0 8px;
        padding-left: 10px;
        border-left: 4px solid color-mix(in srgb, var(--theme-color) 70%, #000);
      }
    </style>

    <meta charset="utf-8" />
    <title>{seoTitle}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* ✅ 基本メタ */}
    <meta name="description" content={metaDescription} />
    <meta name="robots" content="index,follow" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    {/* ✅ Search Console */}
    <meta
      name="google-site-verification"
      content="ELhwwwP8DIFrwsjhnopOuIZnZ_bHVqPRMkcT7q5Dg84"
    />

    {/* ✅ canonical / og:url */}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:url" content={canonicalUrl} />

    {/* ✅ Open Graph */}
    <meta property="og:site_name" content={siteNameSeo} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* ✅ Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/favicon.png" />

    {/* ✅ JSON-LD: WebSite / Organization / Breadcrumbs */}
    {
      websiteJsonLd && (
        <script type="application/ld+json" set:html={websiteJsonLd} />
      )
    }
    {orgJsonLd && <script type="application/ld+json" set:html={orgJsonLd} />}
    {
      breadcrumbJsonLd && (
        <script type="application/ld+json" set:html={breadcrumbJsonLd} />
      )
    }

    <!-- ←ここに追加 -->
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CD6RYL0J10"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        window.dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-CD6RYL0J10");
    </script>
  </head>

  <body
    class={`${bodyClass} ${hasBar2 ? "has-titlebar-2" : "has-titlebar-1"}`}
    style={bodyStyle}
  >
    <TitleBar siteTitle={siteNameBar} pageTitle={barPageTitle} homeHref="/" />

    <main class="app-main">
      <div class="page-wrap">
        {
          showPageHeader && (
            <SiteHeader
              crumbs={crumbs}
              variant={
                /\b(page-nt|page-club)\b/.test(bodyClass) ? "slim" : "boxed"
              }
            >
              {hasUnderTitle && <slot name="under-title" />}
            </SiteHeader>
          )
        }

        <slot />
      </div>
    </main>
  </body>
</html>
