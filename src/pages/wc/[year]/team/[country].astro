      }

      <div class="nt-meta-block">
        {heroMetaLine && <div class="nt-meta-row">{heroMetaLine}</div>}

        {
          (fifaRank || previousEdition || isFirstAppearance) && (
            <div class="nt-meta-row">
              {fifaRank && <span>★ FIFAランク：{fifaRank}位</span>}

              {fifaRank && (previousEdition || isFirstAppearance) && (
                <span class="nt-meta-sep">｜</span>
