---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import RosterView from "../../../../components/RosterView.astro";

import { parseCsv } from "../../../../lib/csvSimple";

import fs from "node:fs";
import path from "node:path";

import { loadCallups, sortForRoster } from "../../../../lib/callups";
import { buildNtColumns } from "../../../../lib/rosterColumns";
import { loadClubMaster } from "../../../../lib/clubMaster";

import { loadGroups } from "../../../../lib/tournamentGroups";
import { loadClubSquads } from "../../../../lib/clubSquads";
import { toYMD } from "../../../../lib/rosterFormat";

import { loadLeagueMaster } from "../../../../lib/leagueMaster";

import { clubUrl, tournamentTopUrl } from "../../../../lib/urls";

// ====================
// getStaticPaths
// 重要：params.country は「未エンコードの国名」を返す
// ====================
export async function getStaticPaths() {
  const rows = loadCallups().filter(
    (r) => String(r.competition ?? "").toUpperCase() === "WC",
  );
  const seen = new Set<string>();
  const paths: { params: { year: string; country: string } }[] = [];

  for (const r of rows as any[]) {
    const year = String(r.edition ?? "").trim();
    const country = String(r.country ?? "").trim(); // ← 未エンコード（日本語）
    if (!year || !country) continue;

    const key = `${year}__${country}`;
    if (seen.has(key)) continue;
    seen.add(key);

    paths.push({ params: { year, country } });
  }

  return paths;
}

// ====================
// page data
// ====================
const { year, country } = Astro.params;

// Astro.params.country は「未エンコードの国名」が入る想定
const countryName = String(country ?? "").trim();

const rowsAll = loadCallups()
  .filter((r: any) => String(r.edition ?? "") === String(year))
  .filter((r: any) => String(r.country ?? "").trim() === countryName);

const competition = "WC";

const competitionLabel = (c: string) => {
  switch (String(c ?? "").toUpperCase()) {
    case "WC":
      return "W杯";
    case "EURO":
      return "EURO";
    case "COPA":
      return "コパ";
    default:
      return c;
  }
};

const compLabel = competitionLabel(competition);

// --------------------
// メタ1行表示（成績 / 監督）
//   - 参照：src/data/nt_tournament_meta.csv
//   - countryName(日本語) -> team_slug は nt_master.csv から解決
// --------------------
type NtMasterRow = {
  team_slug: string;
  country_name_ja: string;
};

type NtTournamentMetaRow = {
  competition: string;
  edition: string;
  team_slug: string;
  coach_ja?: string;
  result_ja?: string;
  host_ja?: string;
};

type FifaRankRow = {
  competition: string;
  year: string;
  country_name_ja: string;
  fifa_rank?: string;
  rank_date?: string;
};

function readCsv(fileName: string) {
  const p = path.join(process.cwd(), "src", "data", fileName);
  const text = fs.readFileSync(p, "utf-8");
  return parseCsv(text);
}

const ntMaster: NtMasterRow[] = readCsv("nt_master.csv").map((r: any) => ({
  team_slug: String(r.team_slug ?? "").trim(),
  country_name_ja: String(r.country_name_ja ?? "").trim(),
}));

const normKey = (s: any) =>
  String(s ?? "")
    .trim()
    .replace(/　/g, " ")
    .replace(/\s+/g, " ");

// teamSlug はこれで
const teamSlug =
  ntMaster.find((r) => normKey(r.country_name_ja) === normKey(countryName))
    ?.team_slug ?? "";

type NtLineupImageRow = {
  competition: string;
  year: string;
  team_slug: string;
  formation: string;
  image: string;
};

const ntLineupImages: NtLineupImageRow[] = readCsv("nt_lineup_images.csv").map(
  (r: any) => ({
    competition: String(r.competition ?? "")
      .trim()
      .toLowerCase(),
    year: String(r.year ?? "").trim(),
    team_slug: String(r.team_slug ?? "").trim(),
    formation: String(r.formation ?? "").trim(),
    image: String(r.image ?? "").trim(),
  }),
);

const ntLineupRow = ntLineupImages.find(
  (r) =>
    r.competition ===
      String(competition ?? "")
        .trim()
        .toLowerCase() &&
    r.year === String(year ?? "").trim() &&
    r.team_slug === String(teamSlug ?? "").trim(),
);

const ntLineupImageSrc = ntLineupRow?.image
  ? `/images/lineups/${ntLineupRow.image}`
  : "";

const ntLineupFormation = String(ntLineupRow?.formation ?? "").trim();

const ntLineupAlt = ntLineupFormation
  ? `${countryName}代表 想定スタメン ${ntLineupFormation}`
  : `${countryName}代表 想定スタメン`;

const hasNtLineupImage = !!ntLineupImageSrc;

const metaAll: NtTournamentMetaRow[] = readCsv("nt_tournament_meta.csv").map(
  (r: any) => ({
    competition: String(r.competition ?? "").trim(),
    edition: String(r.edition ?? "").trim(),
    team_slug: String(r.team_slug ?? "").trim(),
    coach_ja: String(r.coach_ja ?? "").trim(),
    result_ja: String(r.result_ja ?? "").trim(),
    host_ja: String(r.host_ja ?? "").trim(),
  }),
);

const fifaRankAll: FifaRankRow[] = readCsv("fifa_rank.csv").map((r: any) => ({
  competition: String(r.competition ?? "").trim(),
  year: String(r.year ?? "").trim(),
  country_name_ja: String(r.country_name_ja ?? "").trim(),
  fifa_rank: String(r.fifa_rank ?? "").trim(),
  rank_date: String(r.rank_date ?? "").trim(),
}));

const metaRow = metaAll.find(
  (m) =>
    String(m.competition ?? "").toUpperCase() === "WC" &&
    String(m.edition ?? "") === String(year) &&
    String(m.team_slug ?? "") === teamSlug,
);

const fifaRankRow = fifaRankAll
  .filter(
    (r) =>
      String(r.competition ?? "").toUpperCase() === "WC" &&
      String(r.year ?? "").trim() === String(year) &&
      normKey(r.country_name_ja ?? "") === normKey(countryName),
  )
  .sort((a, b) =>
    String(b.rank_date ?? "").localeCompare(String(a.rank_date ?? "")),
  )[0];

const fifaRank = String(fifaRankRow?.fifa_rank ?? "").trim();
const fifaRankDate = String(fifaRankRow?.rank_date ?? "").trim();

// 大会名（開催地）＋年：例「ロシア2018」
// host_ja があれば付ける。無ければ年だけ（例「2018」）
const tournamentLabel = String(metaRow?.host_ja ?? "").trim()
  ? `${String(metaRow?.host_ja ?? "").trim()}${String(year)}`
  : "";

const tournamentHref = `/wc/${year}`;
const tournamentText = `W杯${year}`;

const heroMetaLine = (() => {
  const result = String(metaRow?.result_ja ?? "").trim();
  const coach = String(metaRow?.coach_ja ?? "").trim();

  const coachText = coach ? `監督：${coach}` : "";

  return [result, coachText].filter(Boolean).join(" ｜ ");
})();

const previousMetaRow = metaAll
  .filter(
    (m) =>
      String(m.competition ?? "").toUpperCase() === "WC" &&
      String(m.team_slug ?? "").trim() === teamSlug &&
      Number(String(m.edition ?? "").trim()) < Number(String(year)),
  )
  .sort(
    (a, b) =>
      Number(String(b.edition ?? "").trim()) -
      Number(String(a.edition ?? "").trim()),
  )[0];

const previousEdition = String(previousMetaRow?.edition ?? "").trim();
const previousResult = String(previousMetaRow?.result_ja ?? "").trim();

const previousHasCallups =
  previousEdition &&
  loadCallups().some(
    (r: any) =>
      String(r.competition ?? "").toUpperCase() === "WC" &&
      String(r.edition ?? "").trim() === String(previousEdition) &&
      normKey(r.country ?? "") === normKey(countryName),
  );

const previousTournamentHref =
  previousEdition && previousHasCallups
    ? `/wc/${encodeURIComponent(previousEdition)}/team/${encodeURIComponent(countryName)}`
    : "";

// 更新日（その国×その年 の callups の最新スナップショット）
const maxSnapshot = (() => {
  let max = "";
  for (const r of rowsAll as any[]) {
    const s = toYMD(String((r as any).snapshot_date ?? ""));
    if (s && s > max) max = s;
  }
  return max;
})();

// その国が出場したWCの年（callupsに存在する edition を列挙）
// ※大会ページのグループ/結果が未投入でも、チームページは成立する
const yearsForCountry = Array.from(
  new Set(
    loadCallups()
      .filter((r: any) => String(r.competition ?? "") === "WC")
      .filter((r: any) => String(r.country ?? "").trim() === countryName)
      .map((r: any) => String(r.edition ?? "").trim())
      .filter(Boolean),
  ),
).sort((a, b) => Number(b) - Number(a));

// クラブリンク解決（club_master.csv を使う）
const normalize = (s: any) =>
  String(s ?? "")
    .trim()
    .toLowerCase();

// 選手ごとの「過去に招集された大会（edition）」一覧（リンク用）
const playerKey = (r: any) =>
  `${normalize(r.name_en || r.name_ja)}|${normalize(r.birth_date)}`;

const all = loadCallups();
const wcAllForCountry = all.filter(
  (r) =>
    String(r.competition ?? "").trim() === "WC" &&
    String(r.country ?? "").trim() === countryName,
);

const editionsByPlayer = new Map<string, string[]>();
for (const r of wcAllForCountry) {
  const k = playerKey(r);
  const ed = String(r.edition ?? "").trim();
  if (!ed) continue;
  const arr = editionsByPlayer.get(k) ?? [];
  if (!arr.includes(ed)) arr.push(ed);
  editionsByPlayer.set(k, arr);
}
// 表示は降順に（数字として比較）
for (const [k, arr] of editionsByPlayer) {
  arr.sort((a, b) => Number(b) - Number(a));
  editionsByPlayer.set(k, arr);
}
const groups = loadGroups("WC", String(year), "group");

const callupCountrySetForYear = new Set(
  loadCallups()
    .filter((r: any) => String(r.competition ?? "").toUpperCase() === "WC")
    .filter((r: any) => String(r.edition ?? "").trim() === String(year))
    .map((r: any) => normKey(r.country ?? "")),
);

// その国のグループ（groups.csv から探す）
const norm = (s: any) =>
  String(s ?? "")
    .trim()
    .replace(/　/g, " ")
    .replace(/\s+/g, " ");

// その国の大陸（callupsの最初の行から取れる想定）
const continent = rowsAll[0]?.confederation ?? "";

const group =
  groups.find((g: any) => norm(g.route_param) === norm(countryName))?.group ??
  groups.find((g: any) => norm(g.country_name_ja) === norm(countryName))
    ?.group ??
  "";

// ====================
// 関連国リンク（慎重追加）
//  - 同グループ
//  - 同大陸
//  - PO未確定枠はリンクなし表示
// ====================

const isUndecidedPlayoffLabel = (s: string) => {
  const t = String(s || "").trim();
  return (
    !t ||
    /プレーオフ/i.test(t) ||
    /PO/i.test(t) ||
    /勝者/i.test(t) ||
    /Winner/i.test(t)
  );
};

const makeTeamHref = (name: string) =>
  `/wc/${encodeURIComponent(String(year))}/team/${encodeURIComponent(name)}`;

// groups.csv から同グループ国を作る
const groupRows = group
  ? groups.filter(
      (g: any) => String(g.group ?? "").trim() === String(group).trim(),
    )
  : [];

const groupLinks = groupRows
  .map((g: any) => {
    const rawLabel =
      String(g.country_name_ja ?? "").trim() ||
      String(g.route_param ?? "").trim();

    if (!rawLabel || norm(rawLabel) === norm(countryName)) return null;

    const undecided = isUndecidedPlayoffLabel(rawLabel);
    const label = undecided ? "プレーオフ勝者（未定）" : rawLabel;

    const hasCallups =
      !undecided && callupCountrySetForYear.has(normKey(rawLabel));

    return {
      label,
      href: hasCallups ? makeTeamHref(rawLabel) : "",
      isCurrent: false,
      isUndecided: undecided,
    };
  })
  .filter(Boolean) as {
  label: string;
  href: string;
  isCurrent: boolean;
  isUndecided: boolean;
}[];

// callups から同大陸国を作る（2026同大会のみ）
const continentRowsAll = loadCallups()
  .filter((r: any) => String(r.competition ?? "").toUpperCase() === "WC")
  .filter((r: any) => String(r.edition ?? "") === String(year))
  .filter(
    (r: any) =>
      String(r.confederation ?? "").trim() === String(continent ?? "").trim(),
  );

const continentMap = new Map<
  string,
  { label: string; bucket: string; href: string }
>();

for (const r of continentRowsAll as any[]) {
  const label = String(r.country ?? "").trim();
  if (!label) continue;
  if (norm(label) === norm(countryName)) continue;

  const bucket = String(r.confederation_bucket ?? "")
    .trim()
    .toUpperCase();

  if (!continentMap.has(label)) {
    continentMap.set(label, {
      label,
      bucket,
      href: makeTeamHref(label),
    });
  }
}

// グループ表示と重複する国は除外
const groupLabelSet = new Set(groupLinks.map((x) => norm(x.label)));

const continentLinks = Array.from(continentMap.values())
  .filter((item) => !groupLabelSet.has(norm(item.label)))
  .sort((a, b) => {
    const aQualified = a.bucket === "QUALIFIED" ? 0 : 1;
    const bQualified = b.bucket === "QUALIFIED" ? 0 : 1;
    if (aQualified !== bQualified) return aQualified - bQualified;
    return a.label.localeCompare(b.label, "ja");
  })
  .slice(0, 12);

// 出場ステータス注記（2026のPO/敗退国向け）
const confederationBucket = String(rowsAll[0]?.confederation_bucket ?? "")
  .trim()
  .toUpperCase();

const statusSuffix = (() => {
  if (!confederationBucket || confederationBucket === "QUALIFIED") return "";

  if (
    [
      "INTER_PO",
      "INTERCONF_PO",
      "INTERCONFED_PO",
      "INTERCONTINENTAL_PO",
      "IC_PO",
    ].some(
      (v) =>
        confederationBucket === v || confederationBucket.startsWith(`${v}_`),
    )
  ) {
    return "（大陸間プレーオフ）";
  }

  if (
    ["UEFA_PO", "EU_PO", "EURO_PO", "EUROPE_PO"].some(
      (v) =>
        confederationBucket === v || confederationBucket.startsWith(`${v}_`),
    )
  ) {
    return "（欧州プレーオフ）";
  }

  if (
    ["ELIM", "ELIMINATED"].some(
      (v) =>
        confederationBucket === v || confederationBucket.startsWith(`${v}_`),
    )
  ) {
    return "（予選敗退）";
  }

  return "";
})();

const rows = rowsAll.sort(sortForRoster);

const highlightToken = "2026.03";

const rowHighlightClass = (r: any) => {
  const noteText = String(
    r.notes ?? r.note ?? r.remarks ?? r.note_ja ?? "",
  ).trim();

  return noteText.includes(highlightToken) ? "row-highlight" : "";
};

const currentWcYear = "2026"; // 手動更新：最新大会に合わせて切替
const isCurrentEdition = String(year) === currentWcYear;

const pastYears = yearsForCountry.filter((y) => Number(y) < Number(year));

const isFirstAppearance =
  isCurrentEdition &&
  confederationBucket === "QUALIFIED" &&
  pastYears.length === 0;

// ====================
// 統計（平均年齢 + 5大リーグ）
// ※ 最新大会だけ表示
// ====================

// この国の最新大会だけ表示
const showTeamStats = isCurrentEdition;

// 平均年齢
const calcAge = (birth: string, base: Date) => {
  if (!birth) return null;
  const d = new Date(birth.replace(/\//g, "-"));
  if (isNaN(d.getTime())) return null;

  let age = base.getFullYear() - d.getFullYear();
  const m = base.getMonth() - d.getMonth();
  if (m < 0 || (m === 0 && base.getDate() < d.getDate())) age--;
  return age;
};

const baseDate = new Date(`${year}-06-01`);

const ages = rows
  .map((r: any) => calcAge(String(r.birth_date ?? ""), baseDate))
  .filter((a) => a !== null) as number[];

const avgAge =
  ages.length > 0
    ? (ages.reduce((a, b) => a + b, 0) / ages.length).toFixed(1)
    : "";

// 5大リーグ集計
const clubMaster = loadClubMaster();
const leagueMaster = loadLeagueMaster();

const parseAliases = (aliases: string) =>
  String(aliases || "")
    .split(/[|,、/]/)
    .map((s) => s.trim())
    .filter(Boolean);

const resolveClubMaster = (clubName: string) => {
  const raw = String(clubName || "").trim();
  if (!raw) return null;

  const key = normalize(raw);

  return (
    clubMaster.find((x: any) => {
      const ja = normalize(x.club_display_ja || "");
      const en = normalize(x.club_display_en || "");
      if (key === ja || key === en) return true;

      const als = parseAliases(x.aliases);
      return als.some((a) => normalize(a) === key);
    }) ?? null
  );
};

const leagueKeyToName = new Map(
  leagueMaster.map((l) => [l.league_key, l.league_display_en]),
);

const leagueCounts: Record<string, number> = {};

const clubSquads = loadClubSquads();
const mapped = mapWcToClubSeason(String(year));

if (mapped) {
  for (const r of rows as any[]) {
    const club = String(r.current_club ?? "").trim();
    const c = resolveClubMaster(club);
    if (!c) continue;

    const squad = clubSquads.find(
      (s) =>
        s.season === mapped.season &&
        s.window === mapped.window &&
        s.club_key === c.club_key,
    );

    if (!squad) continue;

    const name = leagueKeyToName.get(squad.league_key);
    if (!name) continue;

    if (!leagueCounts[name]) leagueCounts[name] = 0;
    leagueCounts[name]++;
  }
}

// 5大リーグ順
const leagueOrder = [
  "Premier League",
  "LaLiga",
  "SerieA",
  "Bundesliga",
  "Ligue1",
];

const leagueLabel = (name: string) => {
  switch (name) {
    case "Premier League":
      return "Premier";
    default:
      return name;
  }
};

const leagueText = leagueOrder
  .map((l) =>
    leagueCounts[l] ? `${leagueLabel(l)}: ${leagueCounts[l]}` : null,
  )
  .filter(Boolean)
  .join(" / ");

const starRows = rows
  .filter((r) => String((r as any).is_star ?? "").trim() === "1")
  .slice(0, 3);

const getStarClubInfo = (r: any) => {
  const rawClub = String(r.current_club ?? "").trim();
  const href = clubHref(rawClub);
  const label = clubLabel(rawClub);

  return {
    rawClub,
    href,
    label,
  };
};

// club_squads の存在判定（season + window + league_key + club_key）
const clubSquadKeySet = new Set(
  loadClubSquads().map(
    (r) => `${r.season}|||${r.window}|||${r.league_key}|||${r.club_key}`,
  ),
);

// WCのedition → クラブ側の season/window へ寄せる
function mapWcToClubSeason(edition: string) {
  const y = Number(String(edition || "").trim());
  if (!Number.isFinite(y) || y < 1900) return null;

  // 例外：WC2022（12月開催）→ 2022-23 夏
  if (y === 2022) return { season: "2022-23", window: "summer" as const };

  // 通常：WCは6月（シーズンオフ）→ 前シーズン冬（例：2018→2017-18）
  const prev = y - 1;
  const season = `${prev}-${String(y).slice(2)}`;
  return { season, window: "winter" as const };
}

const clubHref = (clubName: string) => {
  const c = resolveClubMaster(clubName);
  if (!c) return "";

  // ✅ 過去大会：該当seasonのclub_squadsが無ければリンクしない
  const mapped = mapWcToClubSeason(String(year));
  if (!mapped) return "";

  const squadKey = (season: string, window: "summer" | "winter") =>
    `${season}|||${window}|||${c.league_key}|||${c.club_key}`;

  // 第一希望：mapWcToClubSeason の window
  let win: "summer" | "winter" = mapped.window;

  // 無ければ反対側へフォールバック
  if (!clubSquadKeySet.has(squadKey(mapped.season, win))) {
    const alt: "summer" | "winter" = win === "summer" ? "winter" : "summer";
    if (clubSquadKeySet.has(squadKey(mapped.season, alt))) {
      win = alt;
    } else {
      return "";
    }
  }

  // ✅ clubページ側は ?season= &window= を受け取って初期表示を切替できる
  return (
    clubUrl({
      leagueKey: c.league_key,
      clubKey: c.club_key,
      season: mapped.season as any,
    }) + `&window=${encodeURIComponent(win)}`
  );
};

const clubLabel = (clubName: string) => {
  const c = resolveClubMaster(clubName);
  return c?.club_display_ja || clubName;
};

const columns = buildNtColumns({
  isLatestView: true,
  showStats: false,
  clubHref,
  clubLabel, // ← ★追加

  tournamentLinks: (r) => {
    const k = `${normalize(r.name_en || r.name_ja)}|${normalize(r.birth_date)}`;
    const editions = editionsByPlayer.get(k) ?? [];
    return editions.map((ed) => ({
      label: ed,
      href: `/wc/${encodeURIComponent(ed)}/team/${encodeURIComponent(countryName)}`,
    }));
  },
});

const topHref = `/wc/${year}`;

// <title> 用
const pageLabel = `${countryName}代表${statusSuffix ? ` ${statusSuffix}` : ""}`;

const isJapan = countryName === "日本";
const statusText = statusSuffix ? statusSuffix.replace(/[()（）]/g, "") : "";
const statusForText = statusText ? `【${statusText}】` : "";

const title = isJapan
  ? `日本代表メンバー・背番号一覧【W杯${year}最新】｜所属クラブ・招集歴｜海外サッカーDB`
  : `${countryName}代表メンバー・背番号一覧【${compLabel}${year}最新】${statusForText}｜所属クラブ・招集歴｜海外サッカーDB`;

const description = isJapan
  ? `日本代表の最新メンバー・背番号一覧です。W杯${year}の招集候補、所属クラブ、代表デビュー、過去大会招集歴まで確認できます。`
  : `${countryName}代表の最新メンバー・背番号一覧です。${compLabel}${year}${statusText ? `（${statusText}）` : ""}の招集メンバーを掲載。所属クラブ、代表デビュー、過去大会招集歴まで確認できます。`;

const heading = `${countryName}代表 ${compLabel}${year}メンバー一覧`;
---

<BaseLayout
  title={title}
  description={description}
  bodyClass="page-wc"
  bodyStyle="margin:0; font-family: system-ui;"
  showPageHeader={true}
  crumbs={[
    { label: "トップ", href: "/" },
    { label: `WC${year}`, href: topHref },
    { label: countryName },
  ]}
  heading={heading}
>
  {/*  更新日 + メタ（注目選手の上に置く：状態 → 内容の順） */}
  <div class="nt-title-divider" aria-hidden="true"></div>

  <section class="nt-hero" aria-label="代表ページ見出し">
    <div class="nt-hero-main">
      <h1 class="nt-hero-title">
        {countryName}代表 {compLabel}{
          year
        }メンバー一覧｜背番号・所属クラブ・代表歴（最新）
        {statusSuffix && <span class="nt-status-inline">{statusSuffix}</span>}
      </h1>

      <p class="hero-desc">
        <span>
          {countryName}代表の最新メンバー・背番号一覧（{compLabel}{year}）。
          選手一覧では背番号・所属クラブ・代表デビュー・過去大会招集歴まで確認できます。
        </span>
      </p>

      <div class="nt-guide-block" aria-label="関連ページへの導線">
        {
          yearsForCountry.length > 1 && (
            <div class="nt-related-block">
              <div class="nt-related-label">
                👉 {countryName}の過去大会を見る
              </div>
              <div class="pills nt-year-pills">
                {yearsForCountry.map((y) => (
                  <a
                    class={`pill ${String(y) === String(year) ? "is-active" : ""}`}
                    href={`/wc/${y}/team/${encodeURIComponent(countryName)}`}
                  >
                    <span class="dot" aria-hidden="true" />
                    {y}
                  </a>
                ))}
              </div>
            </div>
          )
        }

        {
          (continent || continentLinks.length > 0) && (
            <div class="nt-related-block">
              <div class="nt-related-label">
                👉 {countryName}と同じ大陸の国を見る
              </div>
              <div class="nt-nav-row">
                {continent && (
                  <a
                    class="pill"
                    href={`/wc/${year}?continent=${encodeURIComponent(continent)}#teams`}
                  >
                    🌍 {continent}
                  </a>
                )}

                {continentLinks.map((item) =>
                  item.href ? (
                    <a class="pill nt-related-pill" href={item.href}>
                      {item.label}
                    </a>
                  ) : (
                    <span class="pill nt-related-pill is-muted">
                      {item.label}
                    </span>
                  ),
                )}
              </div>
            </div>
          )
        }

        {
          (group || groupLinks.length > 0) && (
            <div class="nt-related-block">
              <div class="nt-related-label">
                👉 {countryName}と同じグループの国を見る
              </div>
              <div class="nt-nav-row">
                {group && (
                  <a
                    class="pill"
                    href={`/wc/${year}?group=${encodeURIComponent(group)}#teams`}
                  >
                    🔠 グループ {group}
                  </a>
                )}

                {groupLinks.map((item) =>
                  item.href ? (
                    <a class="pill nt-related-pill" href={item.href}>
                      {item.label}
                    </a>
                  ) : (
                    <span class="pill nt-related-pill is-muted">
                      {item.label}
                    </span>
                  ),
                )}
              </div>
            </div>
          )
        }

        <div class="nt-related-block">
          <div class="nt-related-label">👉 大会全体を見る</div>
          <div class="nt-tournament-link">
            <a href={tournamentHref}>← {tournamentText} ポータルページへ</a>
          </div>
        </div>
      </div>

      <div class="nt-guide-divider" aria-hidden="true"></div>

      {
        statusSuffix && (
          <div class="nt-status-note">
            ※ このページは {countryName}代表の
            {statusText ? `（${statusText}）` : ""}
            時点の候補・招集状況を掲載しています。
          </div>
