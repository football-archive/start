---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import RosterView from "../../../../components/RosterView.astro";

import { parseCsv } from "../../../../lib/csvSimple";

import fs from "node:fs";
import path from "node:path";

import { loadCallups, sortForRoster } from "../../../../lib/callups";
import { buildNtColumns } from "../../../../lib/rosterColumns";
import { loadClubMaster } from "../../../../lib/clubMaster";

import { loadGroups } from "../../../../lib/tournamentGroups";
import { loadClubSquads } from "../../../../lib/clubSquads";
import { toYMD } from "../../../../lib/rosterFormat";

import { loadLeagueMaster } from "../../../../lib/leagueMaster";

// ====================
// getStaticPaths
// 重要：params.country は「未エンコードの国名」を返す
// ====================
export async function getStaticPaths() {
  const rows = loadCallups().filter(
    (r) => String(r.competition ?? "").toUpperCase() === "WC",
  );
  const seen = new Set<string>();
  const paths: { params: { year: string; country: string } }[] = [];

  for (const r of rows as any[]) {
    const year = String(r.edition ?? "").trim();
    const country = String(r.country ?? "").trim(); // ← 未エンコード（日本語）
    if (!year || !country) continue;

    const key = `${year}__${country}`;
    if (seen.has(key)) continue;
    seen.add(key);

    paths.push({ params: { year, country } });
  }

  return paths;
}

// ====================
// page data
// ====================
const { year, country } = Astro.params;

// Astro.params.country は「未エンコードの国名」が入る想定
const countryName = String(country ?? "").trim();

const rowsAll = loadCallups()
  .filter((r: any) => String(r.edition ?? "") === String(year))
  .filter((r: any) => String(r.country ?? "").trim() === countryName);

const competition = "WC";

const competitionLabel = (c: string) => {
  switch (String(c ?? "").toUpperCase()) {
    case "WC":
      return "W杯";
    case "EURO":
      return "EURO";
    case "COPA":
      return "コパ";
    default:
      return c;
  }
};

const compLabel = competitionLabel(competition);

// --------------------
// メタ1行表示（成績 / 監督）
//   - 参照：src/data/nt_tournament_meta.csv
//   - countryName(日本語) -> team_slug は nt_master.csv から解決
// --------------------
type NtMasterRow = {
  team_slug: string;
  country_name_ja: string;
};

type NtTournamentMetaRow = {
  competition: string;
  edition: string;
  team_slug: string;
  coach_ja?: string;
  result_ja?: string;
  host_ja?: string;
};

function readCsv(fileName: string) {
  const p = path.join(process.cwd(), "src", "data", fileName);
  const text = fs.readFileSync(p, "utf-8");
  return parseCsv(text);
}

const ntMaster: NtMasterRow[] = readCsv("nt_master.csv").map((r: any) => ({
  team_slug: String(r.team_slug ?? "").trim(),
  country_name_ja: String(r.country_name_ja ?? "").trim(),
}));

const normKey = (s: any) =>
  String(s ?? "")
    .trim()
    .replace(/　/g, " ")
    .replace(/\s+/g, " ");

// teamSlug はこれで
const teamSlug =
  ntMaster.find((r) => normKey(r.country_name_ja) === normKey(countryName))
    ?.team_slug ?? "";

const metaAll: NtTournamentMetaRow[] = readCsv("nt_tournament_meta.csv").map(
  (r: any) => ({
    competition: String(r.competition ?? "").trim(),
    edition: String(r.edition ?? "").trim(),
    team_slug: String(r.team_slug ?? "").trim(),
    coach_ja: String(r.coach_ja ?? "").trim(),
    result_ja: String(r.result_ja ?? "").trim(),
    host_ja: String(r.host_ja ?? "").trim(),
  }),
);

const metaRow = metaAll.find(
  (m) =>
    String(m.competition ?? "").toUpperCase() === "WC" &&
    String(m.edition ?? "") === String(year) &&
    String(m.team_slug ?? "") === teamSlug,
);

// 大会名（開催地）＋年：例「ロシア2018」
// host_ja があれば付ける。無ければ年だけ（例「2018」）
const tournamentLabel = String(metaRow?.host_ja ?? "").trim()
  ? `${String(metaRow?.host_ja ?? "").trim()}${String(year)}`
  : "";

const metaLine = (() => {
  const result = String(metaRow?.result_ja ?? "").trim();
  const coach = String(metaRow?.coach_ja ?? "").trim();

  const parts = [tournamentLabel, result, coach].filter((x) =>
    String(x ?? "").trim(),
  );

  return parts.join(" ｜ ");
})();

// 更新日（その国×その年 の callups の最新スナップショット）
const maxSnapshot = (() => {
  let max = "";
  for (const r of rowsAll as any[]) {
    const s = toYMD(String((r as any).snapshot_date ?? ""));
    if (s && s > max) max = s;
  }
  return max;
})();

// その国が出場したWCの年（callupsに存在する edition を列挙）
// ※大会ページのグループ/結果が未投入でも、チームページは成立する
const yearsForCountry = Array.from(
  new Set(
    loadCallups()
      .filter((r: any) => String(r.competition ?? "") === "WC")
      .filter((r: any) => String(r.country ?? "").trim() === countryName)
      .map((r: any) => String(r.edition ?? "").trim())
      .filter(Boolean),
  ),
).sort((a, b) => Number(b) - Number(a));

// クラブリンク解決（club_master.csv を使う）
const normalize = (s: any) =>
  String(s ?? "")
    .trim()
    .toLowerCase();

// 選手ごとの「過去に招集された大会（edition）」一覧（リンク用）
const playerKey = (r: any) =>
  `${normalize(r.name_en || r.name_ja)}|${normalize(r.birth_date)}`;

const all = loadCallups();
const wcAllForCountry = all.filter(
  (r) =>
    String(r.competition ?? "").trim() === "WC" &&
    String(r.country ?? "").trim() === countryName,
);

const editionsByPlayer = new Map<string, string[]>();
for (const r of wcAllForCountry) {
  const k = playerKey(r);
  const ed = String(r.edition ?? "").trim();
  if (!ed) continue;
  const arr = editionsByPlayer.get(k) ?? [];
  if (!arr.includes(ed)) arr.push(ed);
  editionsByPlayer.set(k, arr);
}
// 表示は降順に（数字として比較）
for (const [k, arr] of editionsByPlayer) {
  arr.sort((a, b) => Number(b) - Number(a));
  editionsByPlayer.set(k, arr);
}
const groups = loadGroups("WC", String(year), "group");

// その国のグループ（groups.csv から探す）
const norm = (s: any) =>
  String(s ?? "")
    .trim()
    .replace(/　/g, " ")
    .replace(/\s+/g, " ");

const group =
  groups.find((g: any) => norm(g.route_param) === norm(countryName))?.group ??
  groups.find((g: any) => norm(g.country_name_ja) === norm(countryName))
    ?.group ??
  "";

// その国の大陸（callupsの最初の行から取れる想定）
const continent = rowsAll[0]?.confederation ?? "";

const rows = rowsAll.sort(sortForRoster);

const highlightToken = "2026.03";

const rowHighlightClass = (r: any) => {
  const noteText = String(
    r.notes ?? r.note ?? r.remarks ?? r.note_ja ?? "",
  ).trim();

  return noteText.includes(highlightToken) ? "row-highlight" : "";
};

const currentWcYear = "2026"; // 手動更新：最新大会に合わせて切替
const isCurrentEdition = String(year) === currentWcYear;

// ====================
// 統計（平均年齢 + 5大リーグ）
// ※ 最新大会だけ表示
// ====================

// この国の最新大会だけ表示
const showTeamStats = isCurrentEdition;

// 平均年齢
const calcAge = (birth: string, base: Date) => {
  if (!birth) return null;
  const d = new Date(birth.replace(/\//g, "-"));
  if (isNaN(d.getTime())) return null;

  let age = base.getFullYear() - d.getFullYear();
  const m = base.getMonth() - d.getMonth();
  if (m < 0 || (m === 0 && base.getDate() < d.getDate())) age--;
  return age;
};

const baseDate = new Date(`${year}-06-01`);

const ages = rows
  .map((r: any) => calcAge(String(r.birth_date ?? ""), baseDate))
  .filter((a) => a !== null) as number[];

const avgAge =
  ages.length > 0
    ? (ages.reduce((a, b) => a + b, 0) / ages.length).toFixed(1)
    : "";

// 5大リーグ集計
const clubMaster = loadClubMaster();
const leagueMaster = loadLeagueMaster();

const parseAliases = (aliases: string) =>
  String(aliases || "")
    .split(/[|,、/]/)
    .map((s) => s.trim())
    .filter(Boolean);

const resolveClubMaster = (clubName: string) => {
  const raw = String(clubName || "").trim();
  if (!raw) return null;

  const key = normalize(raw);

  return (
    clubMaster.find((x: any) => {
      const ja = normalize(x.club_display_ja || "");
      const en = normalize(x.club_display_en || "");
      if (key === ja || key === en) return true;

      const als = parseAliases(x.aliases);
      return als.some((a) => normalize(a) === key);
    }) ?? null
  );
};

const leagueKeyToName = new Map(
  leagueMaster.map((l) => [l.league_key, l.league_display_en]),
);

const leagueCounts: Record<string, number> = {};

for (const r of rows as any[]) {
  const club = String(r.current_club ?? "").trim();
  const c = resolveClubMaster(club);
  if (!c) continue;

  const name = leagueKeyToName.get(c.league_key);
  if (!name) continue;

  if (!leagueCounts[name]) leagueCounts[name] = 0;
  leagueCounts[name]++;
}

// 5大リーグ順
const leagueOrder = [
  "Premier League",
  "LaLiga",
  "SerieA",
  "Bundesliga",
  "Ligue1",
];

const leagueLabel = (name: string) => {
  switch (name) {
    case "Premier League":
      return "Premier";
    default:
      return name;
  }
};

const leagueText = leagueOrder
  .map((l) =>
    leagueCounts[l] ? `${leagueLabel(l)}: ${leagueCounts[l]}` : null,
  )
  .filter(Boolean)
  .join(" / ");

const starRows = rows
  .filter((r) => String((r as any).is_star ?? "").trim() === "1")
  .slice(0, 3);

// club_squads の存在判定（season + window + league_key + club_key）
const clubSquadKeySet = new Set(
  loadClubSquads().map(
    (r) => `${r.season}|||${r.window}|||${r.league_key}|||${r.club_key}`,
  ),
);

// WCのedition → クラブ側の season/window へ寄せる
function mapWcToClubSeason(edition: string) {
  const y = Number(String(edition || "").trim());
  if (!Number.isFinite(y) || y < 1900) return null;

  // 例外：WC2022（12月開催）→ 2022-23 夏
  if (y === 2022) return { season: "2022-23", window: "summer" as const };

  // 通常：WCは6月（シーズンオフ）→ 前シーズン冬（例：2018→2017-18）
  const prev = y - 1;
  const season = `${prev}-${String(y).slice(2)}`;
  return { season, window: "winter" as const };
}

const clubHref = (clubName: string) => {
  const c = resolveClubMaster(clubName);
  if (!c) return "";

  // ✅ 過去大会：該当seasonのclub_squadsが無ければリンクしない
  const mapped = mapWcToClubSeason(String(year));
  if (!mapped) return "";

  const squadKey = (season: string, window: "summer" | "winter") =>
    `${season}|||${window}|||${c.league_key}|||${c.club_key}`;

  // 第一希望：mapWcToClubSeason の window
  let win: "summer" | "winter" = mapped.window;

  // 無ければ反対側へフォールバック
  if (!clubSquadKeySet.has(squadKey(mapped.season, win))) {
    const alt: "summer" | "winter" = win === "summer" ? "winter" : "summer";
    if (clubSquadKeySet.has(squadKey(mapped.season, alt))) {
      win = alt;
    } else {
      return "";
    }
  }

  // ✅ clubページ側は ?season= &window= を受け取って初期表示を切替できる
  return `/clubs/${c.league_key}/${c.club_key}?season=${encodeURIComponent(
    mapped.season,
  )}&window=${encodeURIComponent(win)}`;
};

const columns = buildNtColumns({
  isLatestView: true,
  showStats: false,
  clubHref,

  tournamentLinks: (r) => {
    const k = `${normalize(r.name_en || r.name_ja)}|${normalize(r.birth_date)}`;
    const editions = editionsByPlayer.get(k) ?? [];
    return editions.map((ed) => ({
      label: ed,
      href: `/wc/${encodeURIComponent(ed)}/team/${encodeURIComponent(countryName)}`,
    }));
  },
});

const topHref = `/wc/${year}`;

// <title> 用（共通ヘッダーのページ名にも出る）
const title = `${countryName}代表 ${compLabel}${year}メンバー一覧`;
const description = `${countryName}代表の${compLabel}${year}メンバー一覧。背番号・ポジション・所属クラブなどを掲載。`;
const heading = `${countryName}代表`;
---

<BaseLayout
  title={title}
  description={description}
  bodyClass="page-wc"
  bodyStyle="margin:0; font-family: system-ui;"
  showPageHeader={true}
  crumbs={[
    { label: "トップ", href: "/" },
    { label: `WC${year}`, href: topHref },
    { label: countryName },
  ]}
  heading={heading}
>
  {
    yearsForCountry.length > 1 && (
      <div class="pills nt-year-pills" aria-label="大会年切替">
        {yearsForCountry.map((y) => (
          <a
            class={`pill ${String(y) === String(year) ? "is-active" : ""}`}
            href={`/wc/${y}/team/${encodeURIComponent(countryName)}`}
          >
            <span class="dot" aria-hidden="true" />
            {y}
          </a>
        ))}
      </div>
    )
  }

  {
    (continent || group) && (
      <div class="nt-nav-pills">
        {continent && (
          <a
            class="pill"
            href={`/wc/${year}?continent=${encodeURIComponent(continent)}#teams`}
          >
            🌍 {continent}
          </a>
        )}
        {group && (
          <a
            class="pill"
            href={`/wc/${year}?group=${encodeURIComponent(group)}#teams`}
          >
            🔠 グループ {group}
          </a>
        )}
      </div>
    )
  }

  {/*  更新日 + メタ（注目選手の上に置く：状態 → 内容の順） */}
  <div class="nt-title-divider" aria-hidden="true"></div>

  <section class="nt-hero" aria-label="代表ページ見出し">
    <div class="nt-hero-main">
      <h1 class="nt-hero-title">
        {countryName}代表 {compLabel}{year}メンバー一覧
      </h1>

      <p class="hero-desc">
        {countryName}代表の{compLabel}{
          year
        }メンバー一覧。背番号・所属クラブ・代表デビューなどを掲載。
      </p>

      {metaLine && <div class="nt-hero-meta">{metaLine}</div>}
    </div>

    <div class="nt-updated">
      更新日：
      <span class="updated-date">{toYMD(maxSnapshot) || "—"}</span>
    </div>
  </section>

  <section class="star-block" aria-label="注目選手">
    <h2 class="star-title">⭐ 注目選手</h2>

    {
      starRows.length > 0 ? (
        <div class="star-grid">
          {starRows.map((r) => (
            <div class="star-card">
              <div class="star-name">
                {r.name_ja || r.name_en || r.name}
                <span class="star-pos">
                  （{r.position_primary || r.position}）
                </span>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="star-empty">準備中</div>
      )
    }
  </section>

  {
    showTeamStats && avgAge && (
      <div class="team-stats">
        平均年齢：{avgAge}歳{leagueText ? ` ｜ ${leagueText}` : ""}
      </div>
    )
  }

  <RosterView {rows} {columns} rowClass={rowHighlightClass} />

  <script is:inline define:vars={{ topHref }}>
    const TOP = topHref;

    function updateBackLink() {
      const a = document.getElementById("back-link-anchor");
      if (!a) return false;

      const params = new URLSearchParams(location.search);
      const from = (params.get("from") || "").trim();
      const anchor = (params.get("anchor") || "").trim();

      // デフォルト
      let href = TOP;
      let label = "WC一覧へ戻る";

      // from=group-A
      const mGroup = from.match(/^group-(.+)$/);
      if (mGroup) {
        const g = mGroup[1];
        href = `${TOP}?group=${encodeURIComponent(g)}`;
        label = `グループ${g}へ戻る`;
      }

      // from=conf-UEFA
      const mConf = from.match(/^conf-(.+)$/);
      if (mConf) {
        const conf = mConf[1];
        href = `${TOP}?continent=${encodeURIComponent(conf)}`;
        label = `${conf}へ戻る`;
      }

      if (anchor) href = `${href}#${anchor}`;

      a.href = href;
      a.textContent = `← ${label}`;
      return true;
    }

    function boot() {
      if (updateBackLink()) return;

      let tries = 0;
      const timer = setInterval(() => {
        tries++;
        if (updateBackLink() || tries >= 40) clearInterval(timer);
      }, 50);
    }

    if (document.readyState === "loading") {
      window.addEventListener("DOMContentLoaded", boot);
    } else {
      boot();
    }
  </script>

  {/* JSで文言差し替えもあるので global 推奨 */}
  <style is:global>
    .page-wc .back-link {
      margin: 0 0 10px;
      font-size: 13px;
      color: #374151;
    }
    .page-wc .back-link a {
      color: inherit;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .page-wc .back-link a:hover {
      opacity: 0.85;
    }

    .star-block {
      margin: 12px 0 16px;
      padding: 10px 12px;
      border-radius: 12px;
      background: color-mix(in srgb, var(--theme-color) 26%, #ffffff);
      border-color: color-mix(in srgb, var(--theme-color) 45%, var(--border));
      border: 1px solid rgba(128, 0, 128, 0.18);
    }

    .star-title {
      margin: 0 0 8px;
      font-size: 13px;
      font-weight: 650;
      opacity: 1;
    }

    .star-grid {
      display: grid;
      gap: 10px;
      grid-template-columns: repeat(3, 1fr);
    }

    .star-card {
      background: #fff;
      border: 1px solid rgba(0, 0, 0, 0.05);
      border-radius: 10px;
      padding: 8px 10px;
      display: flex;
      align-items: center;
    }

    .star-name {
      font-weight: 600;
      font-size: 13px;
      line-height: 1.35;
      word-break: keep-all;
    }

    .star-pos {
      font-weight: 500;
      font-size: 12px;
      opacity: 0.7;
      margin-left: 4px;
    }

    .star-empty {
      font-size: 13px;
      opacity: 0.65;
      padding: 8px 4px;
    }

    /* 統計 */
    .team-stats {
      font-size: 13px;
      color: var(--theme-color);
      font-weight: 600;
      margin: 8px 0;
    }

    @media (max-width: 900px) {
      .star-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .nt-hero {
        display: block;
        margin-bottom: 8px;
      }

      .nt-hero-title {
        font-size: 18px;
        line-height: 1.3;
      }

      .nt-hero-meta {
        font-size: 14px;
      }

      .nt-updated {
        margin-top: 4px;
        text-align: left;
        white-space: normal;
      }

      .star-grid {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        grid-template-columns: none;
        padding-bottom: 2px;
        -webkit-overflow-scrolling: touch;
      }

      .star-card {
        flex: 0 0 auto;
        min-width: 170px;
        padding: 6px 10px;
      }

      .star-name {
        font-size: 12px;
        line-height: 1.3;
      }

      .star-pos {
        font-size: 11px;
      }
    }

    .star-empty {
      font-size: 13px;
      opacity: 0.65;
      padding: 8px 4px;
    }

    .page-wc .star-section {
      background: #f3e5f5 !important;
      border-color: rgba(0, 0, 0, 0.08) !important;
      opacity: 1;
    }

    /* 年ピル（代表ページ上部） */
    .nt-year-pills {
      margin: 2px 0 10px;
    }

    /* ===== 代表ページ：大陸・グループナビ ===== */
    .nt-nav-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0 0 8px;
    }

    /* ピル群とタイトル群の区切り */
    .nt-title-divider {
      height: 1px;
      background: color-mix(in srgb, var(--theme-color) 24%, #d1d5db);
      margin: 8px 0 12px;
    }

    /* タイトルブロック */
    .nt-hero {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin: 0 0 10px;
    }

    .nt-hero-main {
      min-width: 0;
    }

    .nt-hero-title {
      margin: 0;
      font-size: clamp(20px, 2.8vw, 26px);
      line-height: 1.25;
      font-weight: 800;
      color: #111;
      letter-spacing: 0.01em;
    }

    .nt-hero-meta {
      margin-top: 4px;
      font-weight: 700;
      font-size: 16px;
      line-height: 1.3;
      color: var(--theme-color);
      word-break: keep-all;
    }

    .page-nt h2,
    .page-nt h3.section-title {
      color: var(--theme-color);
    }

    .hero-desc {
      margin: 6px 0 4px;
      font-size: 13px;
      line-height: 1.45;
      color: #666;
    }

    @media (max-width: 640px) {
      .hero-desc {
        font-size: 12px;
      }
    }

    /* 代表側：更新日（注記） + メタ1行 */
    .nt-meta-line {
      display: flex;
      flex-direction: column;
      gap: 2px;
      margin: 4px 0 10px;
      white-space: normal;
    }

    .nt-updated {
      font-size: 12px;
      opacity: 0.78;
      line-height: 1.2;
      text-align: right;
      white-space: nowrap;
      flex: 0 0 auto;
    }

    .nt-meta {
      align-self: flex-start;
      text-align: left;
      margin-top: 0;
      font-weight: 700;
      font-size: 14px;
      line-height: 1.25;
