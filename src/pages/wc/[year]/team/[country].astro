                    >
                      {previousEdition}
                    </a>
                  ) : (
                    <span class="pill nt-meta-pill nt-meta-pill-inline is-disabled">
                      {previousEdition}
                    </span>
                  )}
                  {previousResult ? ` ${previousResult}` : ""}
                </span>
              )}

              {!previousEdition && isFirstAppearance && <span>㊗️ 初出場</span>}
            </div>
          )
        }

        {
          showTeamStats && avgAge && (
            <div class="nt-meta-row">★ 平均年齢：{avgAge}歳</div>
          )
        }

        {
          showTeamStats && leagueText && (
            <div class="nt-meta-row">★ 5大リーグ所属：{leagueText}</div>
          )
        }

