---
// src/pages/wc/[year]/index.astro
import BaseLayout from "../../../layouts/BaseLayout.astro";

import { loadCallups, countrySlug } from "../../../lib/callups";
import { tournamentTopUrl } from "../../../lib/urls";
import { loadGroups, getGroupsList } from "../../../lib/tournamentGroups";
import { fmtJP } from "../../../lib/updates";

import MatchScheduleTable from "../../../components/MatchScheduleTable.astro";
import {
  loadCompetitionSchedule,
  filterMatches,
  mdNum,
} from "../../../lib/competitionSchedule";

import {
  getGoalRanking,
  getAssistRanking,
  getEventTeamCount,
  addRank,
} from "../../../lib/matchEvents";

import { getAwards } from "../../../lib/competitionAwards";

// --------------------
// getStaticPaths：callups に存在する edition を自動列挙
// --------------------
export async function getStaticPaths() {
  const rows = loadCallups();
  const years = new Set(
    rows
      .filter((r: any) => String(r.competition ?? "") === "WC")
      .map((r: any) => String(r.edition ?? "").trim())
      .filter(Boolean),
  );

  return [...years].map((year) => ({ params: { year } }));
}

const year = String(Astro.params.year ?? "").trim();

const teamCount = getEventTeamCount("WC", String(year));
const showGARank = teamCount >= 20;

const goalRank = showGARank
  ? addRank(getGoalRanking("WC", String(year)), "goals")
  : [];
const assistRank = showGARank
  ? addRank(getAssistRanking("WC", String(year)), "assists")
  : [];

const all = loadCompetitionSchedule();
const matches = filterMatches(all, "WC", String(year)).sort(
  (a, b) => mdNum(a.md) - mdNum(b.md),
);

// URLs
const topHref = tournamentTopUrl({ tournament: "wc", year });

// team 側の getStaticPaths と「同じ slug」
const teamHref = (country: string) => `${topHref}/team/${countrySlug(country)}`;

// ----- callups -----
const rows = loadCallups();
const filtered = (rows as any[]).filter(
  (r) => r.competition === "WC" && String(r.edition) === String(year),
);

const latestCallupSnapshotRaw =
  filtered
    .map((r) => String(r.snapshot_date ?? "").trim())
    .filter(Boolean)
    .sort()
    .at(-1) ?? "";

const latestCallupSnapshot = latestCallupSnapshotRaw
  ? fmtJP(latestCallupSnapshotRaw)
  : "";

// ===== 状態別セット =====
const statusMap = {
  qualified: new Set<string>(),
  playoff: new Set<string>(),
  eliminated: new Set<string>(),
};

for (const r of filtered) {
  const b = String(r.confederation_bucket ?? "").toUpperCase();

  if (!b || b === "QUALIFIED")
    statusMap.qualified.add(String(r.country ?? "").trim());
  else if (b.includes("PO"))
    statusMap.playoff.add(String(r.country ?? "").trim());
  else if (b.includes("ELIM"))
    statusMap.eliminated.add(String(r.country ?? "").trim());
}

// confederation -> countries
const map = new Map<string, string[]>();

for (const r of filtered) {
  const country = String(r.country ?? "").trim();
  if (!country) continue;

  const conf = String(r.confederation ?? "").trim() || "OTHER";
  if (!map.has(conf)) map.set(conf, []);
  const list = map.get(conf)!;
  if (!list.includes(country)) list.push(country);
}

// 表示順
const confOrder = [
  "AFC",
  "CAF",
  "CONCACAF",
  "CONMEBOL",
  "OFC",
  "UEFA",
  "OTHER",
];
const confs = [...map.keys()].sort((a, b) => {
  const ia = confOrder.indexOf(a);
  const ib = confOrder.indexOf(b);
  return (ia === -1 ? 999 : ia) - (ib === -1 ? 999 : ib);
});

// ===== カード表示用に国をまとめて3分類 =====
const allCountries: { country: string; conf: string }[] = [];
for (const conf of confs) {
  const countries = map.get(conf) ?? [];
  for (const country of countries) allCountries.push({ country, conf });
}

const totalCountries = allCountries.length;
const currentWcYear = "2026";
const isCurrentEdition = String(year) === currentWcYear;

const qualifiedCountries = allCountries.filter(({ country }) =>
  statusMap.qualified.has(country),
);
const playoffCountries = allCountries.filter(({ country }) =>
  statusMap.playoff.has(country),
);
const eliminatedCountries = allCountries.filter(({ country }) =>
  statusMap.eliminated.has(country),
);

const featuredCountryCandidates = [
  "日本",
  "スコットランド",
  "イングランド",
  "オランダ",
  "チュニジア",
  "ブラジル",
  "モロッコ",
];

const availableCountrySet = new Set(
  allCountries
    .map(({ country }) => String(country ?? "").trim())
    .filter(Boolean),
);

const featuredCountriesVisible = featuredCountryCandidates.filter((country) =>
  availableCountrySet.has(country),
);

// ===== グループ =====
const groupRows = loadGroups("WC", String(year));
const groups = getGroupsList(groupRows);

// groupSets: group -> [{name, slug, is_placeholder}]
const groupSets: Record<
  string,
  { name: string; slug: string; is_placeholder: boolean }[]
> = {};
for (const r of (groupRows as any[]) || []) {
  const g = String(r.group ?? "").trim();
  if (!g) continue;

  const name = String((r.country_name_ja || r.country_key || "") ?? "").trim();
  if (!name) continue;

  const is_placeholder = String(r.is_placeholder ?? "0") === "1";
  const rawForSlug = String(
    (r.route_param || r.country_key || name) ?? "",
  ).trim();
  const slug = countrySlug(rawForSlug || name);

  if (!groupSets[g]) groupSets[g] = [];
  groupSets[g].push({ name, slug, is_placeholder });
}

// countryName(日本語) -> group letter
const countryToGroup = new Map<string, string>();
for (const g of groups) {
  const items = groupSets[g] || [];
  for (const it of items) {
    if (it.is_placeholder) continue;
    const name = String(it.name ?? "").trim();
    if (!name) continue;
    countryToGroup.set(name, String(g).trim());
  }
}

// ===== 順位表（groups_master拡張版）=====
const standingsByGroup = new Map<string, any[]>();
for (const r of (groupRows as any[]) || []) {
  const g = String(r.group ?? "").trim();
  if (!g) continue;

  if (!standingsByGroup.has(g)) standingsByGroup.set(g, []);
  standingsByGroup.get(g)!.push(r);
}

// 並び順：rankがあればrank、なければslot
for (const [g, list] of standingsByGroup.entries()) {
  list.sort((a, b) => {
    const ra = Number(a.rank ?? 0);
    const rb = Number(b.rank ?? 0);
    if (ra && rb) return ra - rb;
    return Number(a.slot ?? 999) - Number(b.slot ?? 999);
  });
}

const awardGroups = getAwards("WC", String(year));

const wcTitle = `FIFAワールドカップ${year}`;
const teamsHeading = `${wcTitle} 出場国・代表メンバー一覧`;

const pageTitle = `${wcTitle} 出場国・代表メンバー一覧｜日程・グループ・得点ランキング｜海外サッカーDB`;
const pageDesc = isCurrentEdition
  ? `${wcTitle}の出場国一覧と各国の代表メンバーを掲載。グループ、試合日程、得点ランキングも確認できます。最新チーム情報を一覧でチェック。`
  : `${wcTitle}の出場国一覧と各国の代表メンバーを掲載。グループ、試合日程、得点ランキングも確認できます。`;
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  bodyClass="page-wc"
  bodyStyle="margin:0; font-family: system-ui;"
  showPageHeader={true}
  crumbs={[{ label: "トップ", href: "/" }, { label: wcTitle }]}
  heading={teamsHeading}
>
  <style is:global>
    .page-wc .featured-line {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin: 8px 0 14px;
    }

    .page-wc .featured-line .pills {
      flex: 1 1 auto;
    }

    @media (max-width: 560px) {
      .page-wc .featured-line {
        gap: 8px;
        margin: 8px 0 12px;
      }
    }
    .page-wc .quick-title {
      margin: 0 0 10px;
      font-size: 13px;
      color: var(--muted, #666);
    }

    /* headings / labels: theme-driven */
    .page-wc h2,
    .page-wc h3 {
      color: var(--theme-link);
    }

    .page-wc section a {
      color: var(--theme-color);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .page-wc section a:hover {
      color: var(--theme-link);
      background: var(--theme-soft-bg);
    }

    /* pills */
    .page-wc .pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .page-wc .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 10px;
      border-radius: 999px;
      border: 1px solid var(--border, #e6e6e6);
      background: #fff;
      color: #111;
      text-decoration: none;
      font-size: 13px;
      line-height: 1;
      transition:
        transform 0.06s ease,
        box-shadow 0.06s ease;
      user-select: none;
    }
    .page-wc .pill:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
      background: var(--theme-soft-bg);
    }
    .page-wc .pill .dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: var(--theme-color);
      opacity: 0.6;
    }
    /* ✅ active pill: 白背景のまま強調（見えなくならない） */
    .page-wc .pill.is-active {
      background: #fff;
      color: #111;
      border-color: #111;
      font-weight: 800;
    }
    .page-wc .pill.is-active .dot {
      opacity: 1;
    }
    .page-wc .pill.clear {
      background: #f3f4f6;
      border-style: dashed;
    }
    /* clear（全〜）が active になっても視認性キープ */
    .page-wc .pill.clear.is-active {
      background: #f3f4f6;
      color: #111;
      border-color: #111;
    }

    /* filterbar */
    .page-wc .filterbar {
      margin: 10px 0 12px;
      padding: 12px;
      border: 1px solid var(--border, #e6e6e6);
      border-radius: 14px;
      background: #fff;
    }
    .page-wc .filterbar .row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .page-wc .filterbar .count {
      font-size: 13px;
      color: var(--muted, #666);
      white-space: nowrap;
    }
    .page-wc .filterbar input[type="search"] {
      width: min(420px, 100%);
      padding: 8px 10px;
      border-radius: 12px;
      border: 1px solid var(--border, #e6e6e6);
      font-size: 14px;
      outline: none;
    }
    .page-wc .filterbar input[type="search"]:focus {
      border-color: var(--theme-color);
      box-shadow: 0 0 0 3px
        color-mix(in srgb, var(--theme-color) 25%, transparent);
    }

    /* team cards */
    .page-wc .team-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
      gap: 10px;
    }
    .page-wc .team-card {
      display: block;
      border: 1px solid var(--border, #e6e6e6);
      border-radius: 14px;
      background: #fff;
      padding: 10px 12px;
      text-decoration: none;
      color: #111;
      transition:
        transform 0.06s ease,
        box-shadow 0.06s ease;
    }
    .page-wc .team-card:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 22px rgba(0, 0, 0, 0.08);
      background: var(--theme-soft-bg);
    }
    .page-wc .team-card .row1 {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }
    .page-wc .team-card .name {
      font-weight: 800;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    /* ✅ status dot (確実に見える版) */
    .page-wc .status-dot {
      width: 11px;
      height: 11px;
      border-radius: 999px;
      display: inline-block;
      flex: 0 0 auto;
      background: #999; /* fallback */
      box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.1) inset;
      margin-top: 1px;
    }
    .page-wc .status-dot.q {
      background: #22c55e;
    }
    .page-wc .status-dot.p {
      background: #f59e0b;
    }
    .page-wc .status-dot.e {
      background: #ef4444;
    }

    .page-wc .team-card .name {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .page-wc .team-card .meta {
      margin-top: 8px;
      font-size: 12px;
      color: var(--muted, #666);
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .page-wc .badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 999px;
      border: 1px solid var(--border, #e6e6e6);
      font-size: 12px;
      background: #fff;
      white-space: nowrap;
      color: #111;
      text-decoration: none;
    }

    /* group grid */
    .page-wc .group-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px;
      margin: 10px 0 18px;
    }
    .page-wc .group-card {
      border: 1px solid var(--border, #e6e6e6);
      border-radius: 14px;
      background: #fff;
      padding: 12px;
    }
    .page-wc .group-card h3 {
      margin: 0 0 8px;
      font-size: 16px;
      color: var(--theme-link);
    }
    .page-wc .group-card ul {
      margin: 0;
      padding-left: 18px;
      line-height: 1.7;
    }
    .page-wc .group-card .placeholder {
      color: #666;
    }

    .page-wc .mini-standings {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
      font-size: 12px;
    }
    .page-wc .mini-standings th,
    .page-wc .mini-standings td {
      border-top: 1px solid var(--border, #e6e6e6);
      padding: 6px 6px;
      text-align: center;
      white-space: nowrap;
    }
    .page-wc .mini-standings th:first-child,
    .page-wc .mini-standings td:first-child {
      text-align: left;
    }
    .page-wc .mini-standings thead th {
      color: var(--theme-link);
      font-weight: 800;
    }

    /* テーブルは横スクロール前提が安全 */
    /* ===== schedule（試合日程） ===== */

    /* スクロール枠（ここが scroll container になるので sticky が安定） */
    .page-wc .matches-wrap {
      overflow: auto;
      border: 1px solid var(--border, #e6e6e6);
      border-radius: 14px;
      background: #fff;
      max-height: 560px; /* 好みで調整。ページ全体スクロールにしたいなら削除 */
    }

    /* sticky が崩れやすい環境向け（collapseを避ける） */
    .page-wc .matches-wrap table.schedule {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
    }

    /* これがないと「詰まって見える」「表っぽくない」になりがち */
    .page-wc .matches-wrap table.schedule th,
    .page-wc .matches-wrap table.schedule td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--border, #e6e6e6);
      font-size: 13px;
      white-space: nowrap;
      vertical-align: middle;
    }

    /* ヘッダ固定 */
    .page-wc .matches-wrap table.schedule thead th {
      position: sticky;
      top: 0;
      z-index: 5;
      background: #f8fafc;
      border-bottom: 1px solid var(--border, #e6e6e6);
    }

    /* zebra（任意：見やすさUP。不要なら消してOK） */
    .page-wc .matches-wrap table.schedule tbody tr:nth-child(even) td {
      background: #fcfcfd;
    }

    /* 対戦表示（あなたの “home / vs / away” 版のまま） */
    .page-wc .matches-wrap td.col-match {
      display: grid;
      grid-template-columns: 1fr 34px 1fr;
      align-items: center;
      gap: 6px;
    }
    .page-wc .matches-wrap td.col-match .team.home {
      text-align: right;
      font-weight: 700;
    }
    .page-wc .matches-wrap td.col-match .vs {
      text-align: center;
      color: var(--muted, #666);
      font-size: 12px;
    }
    .page-wc .matches-wrap td.col-match .team.away {
      text-align: left;
      font-weight: 700;
    }

    .page-wc td.col-match {
      white-space: nowrap;
    }

    .page-wc td.col-match {
      display: grid;
      grid-template-columns: 1fr 34px 1fr; /* 真ん中を固定幅に */
      align-items: center;
      gap: 6px;
    }

    .page-wc td.col-match .team.home {
      text-align: right;
      font-weight: 700;
    }

    .page-wc td.col-match .vs {
      text-align: center;
      color: var(--muted, #666);
      font-size: 12px;
    }

    .page-wc td.col-match .team.away {
      text-align: left;
      font-weight: 700;
    }

    .page-wc .rank-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 12px;
      margin: 10px 0 18px;
    }
    .page-wc .rank-card {
      border: 1px solid var(--border, #e6e6e6);
      border-radius: 14px;
      background: #fff;
      padding: 12px;
    }
    .page-wc .rank-card h3 {
      margin: 0 0 8px;
      font-size: 16px;
      color: var(--theme-link);
    }
    .page-wc table.rank {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    .page-wc table.rank th,
    .page-wc table.rank td {
      border-top: 1px solid var(--border, #e6e6e6);
      padding: 8px 8px;
      text-align: left;
      white-space: nowrap;
    }
    .page-wc table.rank thead th {
      color: var(--theme-link);
      font-weight: 800;
    }
    .page-wc table.rank td.num,
    .page-wc table.rank th.num {
      text-align: right;
    }
    .page-wc table.rank td.rank,
    .page-wc table.rank th.rank {
      width: 54px;
      text-align: center;
    }
    .page-wc .rank-muted {
      margin: 6px 0 0;
      font-size: 12px;
      color: var(--muted, #666);
    }

    /* グループ勝敗表の国名リンクだけ黒に */
    .page-wc .mini-standings td:first-child a {
      color: #111;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .page-wc .mini-standings td:first-child a:hover {
      color: #000;
      background: #f3f4f6;
    }

    /* グループカード内の国名リンクも黒に */
    .page-wc .group-card ul a {
      color: #111;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .page-wc .group-card ul a:hover {
      color: #000;
      background: #f3f4f6;
    }

    .group-standings-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .group-standings {
      min-width: 520px; /* これが重要：列が潰れない最低幅 */
      border-collapse: collapse;
    }

    .group-standings th,
    .group-standings td {
      white-space: nowrap; /* 数字列を折り返さない */
    }

    /* WCテーマの見出し */
    .page-wc h2,
    .page-wc h3.section-title {
      color: var(--theme-color);
    }

    /* グループカードタイトル */
    .page-wc .group-card h3 {
      color: var(--theme-color);
    }

    /* 表ヘッダ */
    .page-wc thead th {
      color: var(--theme-color);
      font-weight: 600;
    }

    /* 絞り込みリンク */
    .page-wc .filter-link {
      color: var(--theme-color);
    }

    .update-date {
      color: #c62828;
      font-weight: 600;
    }

    .page-wc .filter-line {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin: 10px 0 8px;
    }

    .page-wc .filter-label {
      min-width: 52px;
      font-size: 13px;
      font-weight: 800;
      color: color-mix(in srgb, var(--theme-color) 70%, #111);
      line-height: 34px;
      flex: 0 0 auto;
    }

    .page-wc .filter-line .pills {
      flex: 1 1 auto;
    }

    @media (max-width: 560px) {
      .page-wc .filter-line {
        gap: 8px;
        margin: 8px 0 6px;
      }

      .page-wc .filter-label {
        min-width: 44px;
        font-size: 12px;
        line-height: 30px;
      }
    }

    .page-wc .count {
      font-weight: 600;
      color: var(--theme-color);
    }
  </style>

  <p class="quick-title" style="margin: 6px 0 6px;">
    {wcTitle}の出場国一覧と各国の代表メンバーを掲載しています。
    各チームページでは招集メンバー、所属クラブ、代表歴などを確認できます。
  </p>

  <p class="quick-title" style="margin: 0 0 10px;">
    {isCurrentEdition ? "2026年大会は史上初の48カ国開催。" : ""}
    出場国は大陸別・グループ別に絞り込みできます。
    {
      latestCallupSnapshot ? (
        <span class="update-date">｜最終更新：{latestCallupSnapshot}</span>
      ) : null
    }
  </p>

  {
    isCurrentEdition && (
      <p style="margin: 0 0 14px;">
        <a href={`${topHref}/team/${countrySlug("日本")}`} class="filter-link">
          🇯🇵 日本代表メンバーを見る
        </a>
      </p>
    )
  }

  {
    isCurrentEdition && featuredCountriesVisible.length > 0 && (
      <div class="featured-line">
        <div class="filter-label">注目国</div>
        <div class="pills">
          {featuredCountriesVisible.map((country) => (
            <a
              class="pill"
              href={`${teamHref(country)}?from=featured-countries`}
            >
              <span class="dot" aria-hidden="true" />
              {country}
            </a>
          ))}
        </div>
      </div>
    )
  }

  {
    /* =========================
      (1) 出場国カード：検索/ピル絞り込み（軽量バッジ版）
     ========================= */
  }
  <section id="teams" style="margin: 18px 0;">
    <h2>{teamsHeading}</h2>
    <p class="quick-title" style="margin: 6px 0 10px;">
      出場国を大陸・グループ・状態で絞り込みできます。国名検索にも対応。各カードをクリックすると代表メンバー一覧ページへ移動します。
    </p>

    <div class="filterbar" id="teams-filterbar">
      <div class="row">
        <input
          id="teams-q"
          type="search"
          placeholder="国名で検索（例：日本 / Argentina）"
          autocomplete="off"
          spellcheck={false}
        />
        <div class="count">
          表示：<b id="teams-count">{totalCountries}</b>カ国
        </div>
      </div>

      <div class="filter-line">
        <div class="filter-label">大陸</div>
        <div class="pills" id="teams-conf-pills">
          <a class="pill clear" href={`${topHref}#teams`} data-teams-conf="">
            <span class="dot" aria-hidden="true"></span>全大陸
          </a>
          <a
            class="pill"
            href={`${topHref}?continent=UEFA#teams`}
            data-teams-conf="UEFA"
          >
            <span class="dot" aria-hidden="true"></span>UEFA
          </a>
          <a
            class="pill"
            href={`${topHref}?continent=CONMEBOL#teams`}
            data-teams-conf="CONMEBOL"
          >
            <span class="dot" aria-hidden="true"></span>CONMEBOL
          </a>
          <a
            class="pill"
            href={`${topHref}?continent=CONCACAF#teams`}
            data-teams-conf="CONCACAF"
          >
            <span class="dot" aria-hidden="true"></span>CONCACAF
          </a>
          <a
            class="pill"
            href={`${topHref}?continent=AFC#teams`}
            data-teams-conf="AFC"
          >
            <span class="dot" aria-hidden="true"></span>AFC
          </a>
          <a
            class="pill"
            href={`${topHref}?continent=CAF#teams`}
            data-teams-conf="CAF"
          >
            <span class="dot" aria-hidden="true"></span>CAF
          </a>
          <a
            class="pill"
            href={`${topHref}?continent=OFC#teams`}
            data-teams-conf="OFC"
          >
            <span class="dot" aria-hidden="true"></span>OFC
          </a>
        </div>
      </div>

      <div class="filter-line">
        <div class="filter-label">Group</div>
        <div class="pills" id="teams-group-pills">
          <a class="pill clear" href={`${topHref}#teams`} data-teams-group="">
            <span class="dot" aria-hidden="true"></span>全
          </a>
          {
            groups.map((g) => (
              <a
                class="pill"
                href={`${topHref}?group=${encodeURIComponent(g)}#teams`}
                data-teams-group={String(g).trim()}
              >
                <span class="dot" aria-hidden="true" />
                {g}
              </a>
            ))
          }
        </div>
      </div>

      <div class="filter-line">
        <div class="filter-label">状態</div>
        <div class="pills" id="teams-status-pills">
          <a class="pill clear" href={`${topHref}#teams`} data-teams-status="">
            <span class="dot" aria-hidden="true"></span>全部
          </a>
          <a
            class="pill"
            href={`${topHref}?status=q#teams`}
            data-teams-status="q"
          >
            <span class="dot" aria-hidden="true"></span>出場
          </a>
          <a
            class="pill"
            href={`${topHref}?status=p#teams`}
            data-teams-status="p"
          >
            <span class="dot" aria-hidden="true"></span>PO
          </a>
          <a
            class="pill"
            href={`${topHref}?status=e#teams`}
            data-teams-status="e"
          >
            <span class="dot" aria-hidden="true"></span>敗退
          </a>
        </div>
      </div>

      <div class="team-grid" id="teams-grid">
        {
          qualifiedCountries.map(({ country, conf }) => {
            const g = countryToGroup.get(String(country ?? "").trim()) ?? "";
            return (
              <a
                class="team-card"
                data-team-card
                data-country={country}
                data-conf={conf}
                data-group={g}
                data-status="q"
                href={`${teamHref(country)}?from=teams-card&anchor=teams`}
              >
                <div class="row1">
                  <div class="name">
                    <span class="status-dot q" aria-hidden="true" />
                    {country}
                  </div>
                </div>
                <div class="meta">
                  <span class="badge">{conf}</span>
                  {g ? <span class="badge">grp {g}</span> : null}
                </div>
              </a>
            );
          })
        }

        {
          playoffCountries.map(({ country, conf }) => {
            const g = countryToGroup.get(String(country ?? "").trim()) ?? "";
            return (
              <a
                class="team-card"
                data-team-card
                data-country={country}
                data-conf={conf}
                data-group={g}
                data-status="p"
                href={`${teamHref(country)}?from=po-card&anchor=teams`}
              >
                <div class="row1">
                  <div class="name">
                    <span class="status-dot p" aria-hidden="true" />
                    {country}
                  </div>
                </div>
                <div class="meta">
                  <span class="badge">{conf}</span>
                  {g ? <span class="badge">grp {g}</span> : null}
                </div>
              </a>
            );
          })
        }

        {
          eliminatedCountries.map(({ country, conf }) => {
            const g = countryToGroup.get(String(country ?? "").trim()) ?? "";
            return (
              <a
                class="team-card"
                data-team-card
                data-country={country}
                data-conf={conf}
                data-group={g}
                data-status="e"
                href={`${teamHref(country)}?from=elim-card&anchor=teams`}
              >
                <div class="row1">
                  <div class="name">
                    <span class="status-dot e" aria-hidden="true" />
                    {country}
                  </div>
                </div>
                <div class="meta">
                  <span class="badge">{conf}</span>
                  {g ? <span class="badge">Group {g}</span> : null}
                </div>
              </a>
            );
          })
        }
      </div>

      <p
        class="quick-title"
        id="teams-notfound"
        style="display:none; margin-top:10px;"
      >
        条件に一致する国がありません（絞り込みを解除してみてください）
      </p>
    </div>

    {
      /* =========================
    (3) 日程・試合結果（アンカー用に section wrap）
   ========================= */
    }
    <section id="schedule" style="margin: 18px 0;">
      <h2>日程・試合結果（マッチスケジュール）</h2>
      <p class="quick-title" style="margin: 6px 0 10px;">
        全試合の日程・結果はコチラから（結果は随時更新）
      </p>
      <MatchScheduleTable matches={matches} heading={`WC${year} 日程・結果`} />
    </section>

    {
      /* =========================
      (3) グループ枠（A〜L）
     ========================= */
    }
    <section id="groups" style="margin: 18px 0;">
      <h2>グループ勝敗表（グループステージ）</h2>
      <p class="quick-title" style="margin: 6px 0 10px;">
        各グループの参加国（※プレーオフ枠は確定後にリンク化）
      </p>

      <div class="group-grid">
        {
          groups.map((g) => (
            <div class="group-card">
              <h3>Group {g}</h3>
              <ul>
                {(groupSets[g] || []).map((it) => (
                  <li>
                    {it.is_placeholder ? (
                      <span class="placeholder">{it.name}</span>
                    ) : (
                      <a
                        href={`${topHref}/team/${it.slug}?from=group-card-${encodeURIComponent(
                          g,
                        )}&anchor=groups`}
                      >
                        {it.name}
                      </a>
                    )}
                  </li>
                ))}
              </ul>

              {(() => {
                const s = standingsByGroup.get(g) || [];
                if (s.length === 0) return null;

                const v = (x: any) =>
                  String(x ?? "").trim() ? String(x).trim() : "-";
                const isPH = (r: any) =>
                  String(r.is_placeholder ?? "0") === "1";

                return (
                  <div class="group-standings-wrap">
                    <table
                      class="mini-standings"
                      aria-label={`Group ${g} standings`}
                    >
                      <thead>
                        <tr>
                          <th>国</th>
                          <th>試</th>
                          <th>勝</th>
                          <th>分</th>
                          <th>負</th>
                          <th>得</th>
                          <th>失</th>
                          <th>差</th>
                          <th>点</th>
                        </tr>
                      </thead>
                      <tbody>
                        {s.map((r: any) => (
                          <tr>
                            <td>
                              {isPH(r) ? (
                                <span class="placeholder">
                                  {r.country_name_ja}
                                </span>
                              ) : (
                                <a
                                  href={`${topHref}/team/${countrySlug(
                                    r.route_param ||
                                      r.country_key ||
                                      r.country_name_ja,
                                  )}`}
                                >
                                  {r.country_name_ja}
                                </a>
                              )}
                            </td>
                            <td>{v(r.played)}</td>
                            <td>{v(r.w)}</td>
                            <td>{v(r.d)}</td>
                            <td>{v(r.l)}</td>
                            <td>{v(r.gf)}</td>
                            <td>{v(r.ga)}</td>
                            <td>{v(r.gd)}</td>
                            <td>
                              <b>{v(r.pts)}</b>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                );
              })()}

              <p class="quick-title" style="margin: 10px 0 0;">
                <a href={`${topHref}?group=${encodeURIComponent(g)}#teams`}>
                  グループ{g}の国を絞り込む →
                </a>
              </p>
            </div>
          ))
        }
      </div>
    </section>

    {
      /* =========================
    (4) ランキング（得点 / アシスト）
   ========================= */
    }
    <section id="rankings" style="margin: 18px 0;">
      <h2>得点・アシストランキング</h2>
      <p class="quick-title" style="margin: 6px 0 10px;">
        試合結果・得点・アシストから自動集計しています。
      </p>
      {
        showGARank ? (
          <div class="rank-grid">
            <div class="rank-card">
              <h3>🥇 得点ランキング</h3>
              {goalRank.length === 0 ? (
                <p class="rank-muted">大会前、またはデータ準備中です。</p>
              ) : (
                <table class="rank" aria-label={`WC${year} goal ranking`}>
                  <thead>
                    <tr>
                      <th class="rank">順位</th>
                      <th>選手</th>
                      <th>国</th>
                      <th class="num">得点</th>
                    </tr>
                  </thead>
                  <tbody>
                    {goalRank.slice(0, 30).map((r) => (
                      <tr>
                        <td class="rank">
                          <b>{r.rank}</b>
                        </td>
                        <td>{r.player}</td>
                        <td>
                          <a
                            href={`${teamHref(r.team)}?from=rank-goal&anchor=rankings`}
                          >
                            {r.team}
                          </a>
                        </td>
                        <td class="num">
                          <b>{r.goals}</b>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}
            </div>

            <div class="rank-card">
              <h3>🎯 アシストランキング</h3>
              {assistRank.length === 0 ? (
                <p class="rank-muted">大会前、またはデータ準備中です。</p>
              ) : (
                <table class="rank" aria-label={`WC${year} assist ranking`}>
                  <thead>
                    <tr>
                      <th class="rank">順位</th>
                      <th>選手</th>
                      <th>国</th>
                      <th class="num">アシスト</th>
                    </tr>
                  </thead>
                  <tbody>
                    {assistRank.slice(0, 30).map((r) => (
                      <tr>
                        <td class="rank">
                          <b>{r.rank}</b>
                        </td>
                        <td>{r.player}</td>
                        <td>
                          <a
                            href={`${teamHref(r.team)}?from=rank-assist&anchor=rankings`}
                          >
                            {r.team}
                          </a>
                        </td>
                        <td class="num">
                          <b>{r.assists}</b>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}
            </div>
          </div>
        ) : null
      }
    </section>

    {
      /* =========================
    (5) 表彰（ページ末尾へ移動）
   ========================= */
    }
    <section id="awards" style="margin: 18px 0;">
      <h2>表彰（個人賞・ベストイレブン）</h2>
      <p class="quick-title" style="margin: 6px 0 10px;">
        大会公式の個人賞・ベストイレブンを掲載
      </p>

      {
        awardGroups.length === 0 ? (
          <p class="rank-muted">大会前、またはデータ準備中です。</p>
        ) : (
          <div class="rank-grid">
            {awardGroups.map((g) => (
              <div class="rank-card">
                <h3>🏅 {g.name}</h3>
                <ul style="margin:0; padding-left:18px; line-height:1.7;">
                  {g.items.map((r) => {
                    const rankLabel =
                      g.key === "golden_ball"
                        ? r.rank === "1"
                          ? "ゴールデンボール"
                          : r.rank === "2"
                            ? "シルバーボール"
                            : r.rank === "3"
                              ? "ブロンズボール"
                              : r.rank
                        : r.rank;

                    return (
                      <li>
                        <span style="color:var(--muted,#666); margin-right:6px;">
                          {rankLabel ? `${rankLabel}:` : ""}
                        </span>
                        <b>{r.player}</b>
                        {r.team ? <span>（{r.team}）</span> : null}
                        {r.note ? (
                          <span style="color:var(--muted,#666);">
                            {" "}
                            - {r.note}
                          </span>
                        ) : null}
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))}
          </div>
        )
      }
    </section>

    <script is:inline>
      const $ = (sel) => document.querySelector(sel);
      const $$ = (sel) => Array.from(document.querySelectorAll(sel));

      const norm = (s) => String(s ?? "").trim();
      const normLower = (s) => norm(s).toLowerCase();

      function setActivePills(containerSel, key, value) {
        $$(containerSel + " [data-" + key + "]").forEach((a) => {
          const v = a.getAttribute("data-" + key) ?? "";
          a.classList.toggle("is-active", v === (value ?? ""));
        });
      }

      function updateCounts(visible) {
        const elCount = $("#teams-count");
        if (elCount) elCount.textContent = String(visible);
      }

      function readTeamsStateFromUrl() {
        const params = new URLSearchParams(location.search);
        return {
          conf: norm(params.get("continent")), // e.g. UEFA
          group: norm(params.get("group")), // e.g. A
          status: norm(params.get("status")), // q|p|e
          q: norm($("#teams-q")?.value),
        };
      }

      function writeUrl(state) {
        const params = new URLSearchParams(location.search);

        if (state.conf) params.set("continent", state.conf);
        else params.delete("continent");

        if (state.group) params.set("group", state.group);
        else params.delete("group");

        if (state.status) params.set("status", state.status);
        else params.delete("status");

        const next = params.toString();
        const url = next ? `?${next}#teams` : `#teams`;
        history.replaceState(null, "", url);
      }

      function applyTeamsFilter(state) {
        const cards = $$("[data-team-card]");

        const q = normLower(state.q);
        const conf = norm(state.conf);
        const group = norm(state.group);
        const status = norm(state.status);

        let visible = 0;

        cards.forEach((card) => {
          const cName = normLower(card.getAttribute("data-country"));
          const cConf = norm(card.getAttribute("data-conf"));
          const cGroup = norm(card.getAttribute("data-group"));
          const cStatus = norm(card.getAttribute("data-status"));

          const okQ = !q || cName.includes(q);
          const okConf = !conf || cConf === conf;
          const okGroup = !group || cGroup === group;
          const okStatus = !status || cStatus === status;

          const ok = okQ && okConf && okGroup && okStatus;

          card.style.display = ok ? "" : "none";
          if (ok) visible++;
        });

        updateCounts(visible);

        const nf = $("#teams-notfound");
        if (nf) nf.style.display = visible === 0 ? "" : "none";

        setActivePills("#teams-conf-pills", "teams-conf", conf);
        setActivePills("#teams-group-pills", "teams-group", group);
        setActivePills("#teams-status-pills", "teams-status", status);
      }

      window.addEventListener("DOMContentLoaded", () => {
        const qInput = $("#teams-q");

        // 初期反映
        const init = readTeamsStateFromUrl();
        applyTeamsFilter(init);

        if (qInput) {
          qInput.addEventListener("input", () => {
            const st = readTeamsStateFromUrl();
            applyTeamsFilter(st);
          });
        }

        // pills (即時反映)
        $$("#teams-conf-pills [data-teams-conf]").forEach((a) => {
          a.addEventListener("click", (e) => {
            e.preventDefault();
            const st = readTeamsStateFromUrl();
            st.conf = a.getAttribute("data-teams-conf") ?? "";
            writeUrl(st);
            applyTeamsFilter(st);
          });
        });

        $$("#teams-group-pills [data-teams-group]").forEach((a) => {
          a.addEventListener("click", (e) => {
            e.preventDefault();
            const st = readTeamsStateFromUrl();
            st.group = a.getAttribute("data-teams-group") ?? "";
            writeUrl(st);
            applyTeamsFilter(st);
          });
        });

        $$("#teams-status-pills [data-teams-status]").forEach((a) => {
          a.addEventListener("click", (e) => {
            e.preventDefault();
            const st = readTeamsStateFromUrl();
            st.status = a.getAttribute("data-teams-status") ?? "";
            writeUrl(st);
            applyTeamsFilter(st);
          });
        });

        window.addEventListener("popstate", () => {
          applyTeamsFilter(readTeamsStateFromUrl());
        });
      });
    </script>
  </section>
</BaseLayout>
