---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getUclSeasons } from "../../lib/ucl";

const seasons = getUclSeasons()
  .map((s) => String(s).trim())
  .sort()
  .reverse();
const latest = seasons[0] ?? "2025-26";

const title = "UEFA Champions League｜シーズン一覧";
---

<BaseLayout
  title={title}
  description="UEFAチャンピオンズリーグ（CL）のシーズン一覧ページです。各シーズンの順位表や出場クラブ、結果を確認できます。"
  bodyClass="page-ucl"
  bodyStyle="margin:0; font-family: system-ui;"
  showPageHeader={true}
  crumbs={[{ label: "トップ", href: "/" }, { label: "UCL" }]}
  heading=""
>
  <h1 class="page-title">UEFAチャンピオンズリーグ（CL）シーズン一覧</h1>

  <p class="lead">
    UEFAチャンピオンズリーグ（CL）のシーズン一覧ページです。各シーズンの順位表や出場クラブ、結果を確認できます。リーグフェーズ（新形式）を中心に掲載しています。
  </p>

  <div class="pill-block">
    <div class="pill-label">👉 最新シーズンを見る</div>
    <div class="pills">
      <a class="pill is-active" href={`/ucl/${encodeURIComponent(latest)}`}>
        <span class="dot" aria-hidden="true"></span>最新：{latest}
      </a>
    </div>
  </div>

  <div class="box">
    <h2>掲載シーズン</h2>
    <ul>
      {
        seasons.map((s) => (
          <li>
            <a href={`/ucl/${encodeURIComponent(s)}`}>UEFA CL {s}（順位表）</a>
          </li>
        ))
      }
    </ul>
    <p class="note">
      ※
      各シーズンページでは、順位表・出場クラブ・クラブ詳細へのリンクを掲載しています。
    </p>
  </div>

  <style is:global>
    .page-ucl .muted {
      color: #666;
      font-size: 12.5px;
      margin: 6px 0 10px;
    }
    .page-ucl .box {
      background: #fff;
      border: 1px solid #e6e6e6;
      border-radius: 12px;
      padding: 14px;
    }
    .page-ucl ul {
      margin: 8px 0 0;
      padding-left: 18px;
    }
    .page-ucl li {
      margin: 6px 0;
    }
    .page-ucl a {
      color: #111;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .page-ucl a:hover {
      background: #eef6fd;
    }

    .page-ucl .pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .page-ucl .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 10px;
      border-radius: 999px;
      border: 1px solid #cfe0ff;
      background: #fff;
      color: #111;
      text-decoration: none;
      font-size: 13px;
      line-height: 1;
    }
    .page-ucl .pill:hover {
      background: #eef6fd;
    }
    .page-ucl .pill .dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #2563eb;
      opacity: 0.6;
    }
    .page-ucl .pill.is-active {
      font-weight: 800;
      border-color: #2563eb;
    }
    .page-ucl .pill.is-active .dot {
      opacity: 1;
    }

    .page-ucl .page-title {
      margin: 6px 0 10px;
      font-size: 28px;
      line-height: 1.35;
      color: #111;
    }

    .page-ucl .lead {
      margin: 4px 0 14px;
      font-size: 13px;
      color: #666;
      line-height: 1.6;
    }

    .page-ucl .pill-block {
      margin: 10px 0 14px;
    }

    .page-ucl .pill-label {
      font-size: 13px;
      color: #666;
      margin-bottom: 6px;
      font-weight: 600;
    }

    .page-ucl .box h2 {
      margin: 0 0 8px;
      font-size: 20px;
    }

    .page-ucl .note {
      margin: 10px 0 0;
      font-size: 12.5px;
      color: #666;
    }
  </style>
</BaseLayout>
