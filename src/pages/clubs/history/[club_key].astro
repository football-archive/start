---
import BaseLayout from "../../../layouts/BaseLayout.astro";

import fs from "node:fs";
import path from "node:path";
import { parseCsv } from "../../../lib/csvSimple";

import { loadClubMaster } from "../../../lib/clubMaster";
import { loadLeagueMaster } from "../../../lib/leagueMaster";
import { loadClubSquads } from "../../../lib/clubSquads";
import { toYMD } from "../../../lib/rosterFormat";

// ✅ ここは存在する前提で静的 import（スコープ事故を潰す）
import { STRONG_CLUBS } from "../../../lib/strongClubs";

const latestClubHistoryUpdate = (() => {
  let max = "";
  for (const r of loadClubSquads()) {
    const s = toYMD(String(r.snapshot_date ?? ""));
    if (s && s > max) max = s;
  }
  return max;
})();

type CtMasterRow = {
  club_key: string;
  club_name_ja?: string;
  league_key?: string;
  league_titles_all_time?: string;
  notes?: string;
  display_tier?: string;
  cl_titles_all_time?: string; // 任意（将来用）
};

type CtSeasonMetaRow = {
  season: string;
  league_key: string;
  club_key: string;
  rank_ja?: string;
  coach_ja?: string;
  comment_ja?: string;
};

// --------------------
// helpers
// --------------------
function readCsv(fileName: string) {
  const p = path.join(process.cwd(), "src", "data", fileName);
  const text = fs.readFileSync(p, "utf-8");
  return parseCsv(text);
}

function toNum(v: any) {
  const n = Number(String(v ?? "").trim());
  return Number.isFinite(n) ? n : null;
}

function seasonStart(season: string) {
  const m = String(season ?? "").match(/^(\d{4})/);
  return m ? Number(m[1]) : 0;
}

function isLeagueChampion(rankJa: string) {
  const t = String(rankJa ?? "").trim();
  if (!t) return false;
  return t.includes("優勝") ;
}

function uniqCount(arr: string[]) {
  return new Set(arr.filter(Boolean)).size;
}

// --------------------
// getStaticPaths：ct_master.csv から club_key を列挙
// ✅ readCsv を使わず、代表側同様に getStaticPaths 内で完結（スコープ事故を回避）
// --------------------
export async function getStaticPaths() {
  const p = path.join(process.cwd(), "src", "data", "ct_master.csv");
  const text = fs.readFileSync(p, "utf-8");
  const rows: any[] = parseCsv(text);

  const keys = rows.map((r) => String(r.club_key ?? "").trim()).filter(Boolean);

  const finalKeys =
    STRONG_CLUBS && STRONG_CLUBS.length
      ? STRONG_CLUBS.filter((k) => keys.includes(k))
      : Array.from(new Set(keys));

  return finalKeys.map((club_key) => ({ params: { club_key } }));
}

// --------------------
// Params
// --------------------
const { club_key } = Astro.params;
const clubKey = String(club_key ?? "").trim();

const clubMaster = loadClubMaster();
const leagueMaster = loadLeagueMaster();
const clubSquads = loadClubSquads();

// ct_master（リーグ優勝回数・notesなど）
const ctAll: CtMasterRow[] = readCsv("ct_master.csv").map((r: any) => ({
  club_key: String(r.club_key ?? "").trim(),
  club_name_ja: String(r.club_name_ja ?? r.club_display_ja ?? "").trim(),
  league_key: String(r.league_key ?? "").trim(),
  display_tier: String(r.display_tier ?? "").trim(),
  league_titles_all_time: String(r.league_titles_all_time ?? "").trim(),
  cl_titles_all_time: String(r.cl_titles_all_time ?? "").trim(),
  notes: String(r.notes ?? "").trim(),
}));

const ct = ctAll.find((r) => r.club_key === clubKey);

// 表示名・リーグ表示
const clubInfo: any = clubMaster.find(
  (c: any) => String(c.club_key) === String(clubKey),
);

const clubNameJa =
  String(ct?.club_name_ja ?? "").trim() ||
  String(clubInfo?.club_display_ja ?? "").trim() ||
  clubKey;

const leagueKey =
  String(ct?.league_key ?? "").trim() ||
  String(clubInfo?.league_key ?? "").trim();

const leagueInfo: any = leagueMaster.find(
  (l: any) => String(l.league_key) === String(leagueKey),
);
const leagueName =
  String(leagueInfo?.league_display ?? "").trim() ||
  String(clubInfo?.league_display ?? "").trim() ||
  String(leagueKey);

// all-time wins（通算：プレミア前身なども含む“あなたの方針”）
const leagueTitlesAllTime = toNum(ct?.league_titles_all_time);

// ct_season_meta（シーズン別 成績・監督・コメント）
const metaAll: CtSeasonMetaRow[] = readCsv("ct_season_meta.csv").map(
  (r: any) => ({
    season: String(r.season ?? "").trim(),
    league_key: String(r.league_key ?? "").trim(),
    club_key: String(r.club_key ?? "").trim(),
    rank_ja: String(r.rank_ja ?? "").trim(),
    coach_ja: String(r.coach_ja ?? "").trim(),
    comment_ja: String(r.comment_ja ?? "").trim(),
  }),
);

const rows = metaAll
  .filter((r) => r.club_key === clubKey)
  .sort((a, b) => seasonStart(b.season) - seasonStart(a.season));

const seasonsCount = rows.length;

// 収録シーズン（注釈用）
const seasonYears = rows.map((r) => seasonStart(r.season)).filter(Boolean);
const minYear = seasonYears.length ? Math.min(...seasonYears) : null;
const maxYear = seasonYears.length ? Math.max(...seasonYears) : null;
const coverageText =
  minYear && maxYear ? `${minYear}-${maxYear + 1}` : `準備中`;

// 年代別 “リーグ優勝推移”
type DecadeRow = { decade: string; titles: number };
const decadeMap = new Map<string, number>();
for (const r of rows) {
  const y = seasonStart(r.season);
  if (!y) continue;
  const d = `${Math.floor(y / 10) * 10}年代`;
  if (!decadeMap.has(d)) decadeMap.set(d, 0);
  if (isLeagueChampion(r.rank_ja ?? ""))
    decadeMap.set(d, (decadeMap.get(d) ?? 0) + 1);
}
const decadeRows: DecadeRow[] = Array.from(decadeMap.entries())
  .map(([decade, titles]) => ({ decade, titles }))
  .sort(
    (a, b) =>
      Number(a.decade.replace("年代", "")) -
      Number(b.decade.replace("年代", "")),
  );

// pills（親と同じ並びを優先）
const pillKeys =
  STRONG_CLUBS && STRONG_CLUBS.length
    ? STRONG_CLUBS
    : ctAll.map((r) => r.club_key).filter(Boolean);

const pillItems = pillKeys
  .map((k) => {
    const m = ctAll.find((x) => x.club_key === k);
    const name =
      String(m?.club_name_ja ?? "").trim() ||
      String(
        clubMaster.find((c: any) => String(c.club_key) === String(k))
          ?.club_display_ja ?? "",
      ).trim() ||
      k;

    const tier = String(m?.display_tier ?? "").trim();

    return { key: k, name, tier };
  })
  .filter((x) => x.key && x.name);

// スマホ用：tier1 + 現在見ているクラブ は表示
const pillItemsMobile = pillItems.filter(
  (p) => p.tier === "1" || p.key === clubKey,
);

// squad data: season ごとの人数 & 有無（無ければ disable）
function seasonSquadCount(season: string) {
  const s = String(season ?? "").trim();
  if (!s) return 0;
  const hit = clubSquads.filter(
    (r: any) =>
      String(r.club_key ?? "").trim() === clubKey &&
      String(r.season ?? "").trim() === s,
  );
  // name_en を優先しつつ、無ければ name_ja でユニーク
  const keys = hit
    .map((r: any) => String(r.name_en ?? r.name_ja ?? "").trim())
    .filter(Boolean);
  return uniqCount(keys);
}

// link: 既存クラブ詳細（スカッド）へ season クエリで飛ばす
const clubSquadHref = (season: string) =>
  leagueKey && clubKey
    ? `/clubs/${encodeURIComponent(leagueKey)}/${encodeURIComponent(clubKey)}?season=${encodeURIComponent(season)}`
    : `/clubs`;

// meta
const heading = `${clubNameJa}のあゆみ（国内リーグ）`;
const title = `${heading}｜World Football Archive`;
const description = `${clubNameJa}の国内リーグにおける歩みを、シーズン別（監督・成績・時代メモ）で一覧化。リーグ通算優勝回数と年代別の推移もまとめたアーカイブ。`;
---

<BaseLayout
  title={title}
  description={description}
  bodyClass="page-ct page-ct-hub"
  bodyStyle="margin:0; font-family: system-ui;"
  showPageHeader={true}
  crumbs={[
    { label: "トップ", href: "/" },
    { label: "クラブ", href: "/clubs" },
    { label: "クラブのあゆみ", href: "/clubs/history" },
    { label: clubNameJa },
  ]}
  heading={heading}
>
  <div class="section-wrap">
    <div class="backline">
      <a class="back" href="/clubs/history">← クラブのあゆみ（一覧）に戻る</a>
    </div>

    <div class="strong-pills strong-pills--desktop" aria-label="強豪クラブ">
      {
        pillItems.map((p) => (
          <a
            class={`pill ${p.key === clubKey ? "is-active" : ""}`}
            href={`/clubs/history/${encodeURIComponent(p.key)}`}
          >
            {p.name}
          </a>
        ))
      }
    </div>

    <div class="strong-pills strong-pills--mobile" aria-label="強豪クラブ">
      {
        pillItemsMobile.map((p) => (
          <a
            class={`pill ${p.key === clubKey ? "is-active" : ""}`}
            href={`/clubs/history/${encodeURIComponent(p.key)}`}
          >
            {p.name}
          </a>
        ))
      }
    </div>

    <div class="lead">
      <p>
        {
          clubNameJa
        }の国内リーグにおける歩みを、シーズン別（監督・成績・時代メモ）で一覧化しました。（対象リーグ：{
          leagueName
        }）
      </p>
    </div>

    <p class="page-update">
      最終更新：
      <span class="update-date">{latestClubHistoryUpdate || "—"}</span>
    </p>

    <div class="summary-block">
      <div class="chips-line" aria-label="概要">
        <div class="chips">
          <div class="chip">
            <span class="k">リーグ</span>
            <span class="v">{leagueName}</span>
          </div>

          <div class="chip">
            <span class="k">通算リーグ優勝</span>
            <span class="v">{leagueTitlesAllTime ?? "—"}回</span>
          </div>

          <div class="chip chip-coverage">
            <span class="k">掲載済シーズン</span>
            <span class="v">{coverageText}</span>
          </div>
        </div>

        <div class="chips-note">※表は掲載済シーズン内の集計です</div>
      </div>
    </div>

    {/* 年代別（復活） */}
    {
      decadeRows.length > 0 && (
        <section class="decade" aria-label="年代別 リーグ優勝の推移">
          <h2 class="sec-title">年代別 リーグ優勝の推移</h2>
          <div class="block">
            <div class="table-wrap">
              <table class="tbl decade-tbl">
                <thead>
                  <tr>
                    <th>年代</th>
                    <th class="num">優勝回数</th>
                  </tr>
                </thead>
                <tbody>
                  {decadeRows.map((r) => (
                    <tr>
                      <td>{r.decade}</td>
                      <td class="num">{r.titles}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </section>
      )
    }

    <section class="cards" aria-label="シーズン一覧">
      {
        rows.map((r) => {
          const season = String(r.season ?? "").trim();
          const coach = String(r.coach_ja ?? "").trim();
          const rank = String(r.rank_ja ?? "").trim();
          const comment = String(r.comment_ja ?? "").trim();

          const members = seasonSquadCount(season);
          const hasRoster = members > 0;

          const href = clubSquadHref(season);

          return (
            <>
              {hasRoster ? (
                <a class="card" href={href}>
                  <div class="card-top">
                    <div class="ed">
                      <span class="ed-year">{season}</span>
                      <span class="ed-badge">LEAGUE</span>
                    </div>
                  </div>

                  <div class="meta">
                    <div class="row">
                      <span class="k">監督</span>
                      <span class="v">{coach || "—"}</span>
                    </div>
                    <div class="row">
                      <span class="k">成績</span>
                      <span class="v v-accent">{rank || "—"}</span>
                    </div>
                  </div>

                  {comment && (
                    <div class="comment">
                      <span class="c-ico">💬</span>
                      <span class="c-txt">{comment}</span>
                    </div>
                  )}

                  <div class="footer">
                    <span class="members">
                      {season} スカッド →
                      <span class="members-n">({members}人)</span>
                    </span>
                  </div>
                </a>
              ) : (
                <div class="card is-empty" aria-disabled="true">
                  <div class="card-top">
                    <div class="ed">
                      <span class="ed-year">{season}</span>
                      <span class="ed-badge">LEAGUE</span>
                    </div>
                  </div>

                  <div class="meta">
                    <div class="row">
                      <span class="k">監督</span>
                      <span class="v">{coach || "—"}</span>
                    </div>
                    <div class="row">
                      <span class="k">成績</span>
                      <span class="v v-accent">{rank || "—"}</span>
                    </div>
                  </div>

                  {comment && (
                    <div class="comment">
                      <span class="c-ico">💬</span>
                      <span class="c-txt">{comment}</span>
                    </div>
                  )}

                  <div class="footer">
                    <span class="prep">準備中</span>
                  </div>
                </div>
              )}
            </>
          );
        })
      }
    </section>

    <style is:global>
      /* =========================
        page-ct-hub (club history)
      ========================= */
      .page-ct-hub .section-wrap {
        max-width: 1100px;
        margin: 0 auto;
      }

      .page-ct-hub .backline {
        margin: 4px 0 10px;
      }
      .page-ct-hub .back {
        display: inline-block;
        text-decoration: none;
        font-size: 13px;
        font-weight: 800;
        color: var(--color-club);
      }

      .page-ct-hub .lead {
        margin: 0px 0 6px;
        color: #374151;
        font-size: 14px;
        line-height: 1.35;
      }

      .page-update {
        margin: -6px 0 10px;
        font-size: 12px;
        color: var(--muted, #666);
        text-align: right;
      }

      .page-update .update-date {
        color: #c62828;
        font-weight: 700;
      }

      /* pills */
      .page-ct-hub .strong-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 12px;
        padding-bottom: 10px;
        margin-bottom: 10px;
        border-bottom: 1px solid rgba(0, 0, 0, 0.08);
      }

      .page-ct-hub .strong-pills--mobile {
        display: none;
      }

      @media (max-width: 560px) {
        .page-ct-hub .strong-pills--desktop {
          display: none;
        }

        .page-ct-hub .strong-pills--mobile {
          display: flex;
        }
      }

      .page-ct-hub .pill {
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: #fff;
        font-size: 13px;
        text-decoration: none;
        color: #111;
        white-space: nowrap;
      }
      .page-ct-hub .pill:hover {
        border-color: color-mix(
          in srgb,
          var(--color-club) 35%,
          rgba(0, 0, 0, 0.08)
        );
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
      }
      .page-ct-hub .pill.is-active {
        background: color-mix(in srgb, var(--color-club) 14%, white);
        border-color: color-mix(
          in srgb,
          var(--color-club) 30%,
          rgba(0, 0, 0, 0.08)
        );
      }

      .page-ct-hub .summary-block {
        margin-bottom: 8px;
        margin: 0 0 6px;
      }

      .page-ct-hub .summary-block .lead {
        margin: 0 0 4px;
      }

      .page-ct-hub .summary-block .chips-line {
        margin: 0;
      }
      /* chips */
      .page-ct-hub .chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        min-width: 0;
        margin: 0; /* ★ 10px を消す */
        padding: 0; /* 念のため */
      }
      .page-ct-hub .chip {
        display: inline-flex;
        gap: 6px;
        align-items: baseline;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 999px;
        padding: 4px 10px;
        background: #fafafa;
        font-size: 12px;
      }
      .page-ct-hub .chip .k {
        opacity: 0.7;
      }
      .page-ct-hub .chip .v {
        font-weight: 800;
      }
      /* chips + coverage を 1行にまとめる */
      .page-ct-hub .chips-line {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap; /* 画面が狭い時は自然に折り返し */
        margin: 2px 0 4px;
      }

      /* 既存chipsを横並び維持 + 折り返し */
      .page-ct-hub .chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        min-width: 0;
      }

      /* coverageチップが長い時に省略 */
      .page-ct-hub .chip-coverage .v {
        max-width: 260px; /* PC想定。必要なら調整 */
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* 右端の注釈（小さく） */
      .page-ct-hub .chips-note {
        font-size: 12px;
        color: #6b7280;
        white-space: nowrap;
        margin-left: auto;
      }

      /* できるだけ右寄せ（PCで気持ちいい） */
      @media (min-width: 860px) {
        .page-ct-hub .chips-line {
          justify-content: space-between;
        }
      }

      /* スマホは無理に右寄せせず、自然に折り返す */
      @media (max-width: 859px) {
        .page-ct-hub .chips-note {
          white-space: normal;
        }
        .page-ct-hub .chip-coverage .v {
          max-width: 220px;
        }
      }

      .page-ct-hub .coverage {
        margin: 6px 0 0;
        font-size: 12.5px;
        font-weight: 800;
        color: #111;
      }
      .page-ct-hub .coverage-note {
        margin: 4px 0 14px;
        font-size: 12px;
        opacity: 0.7;
      }

      .page-ct-hub .decade {
        margin-top: 8px;
      }
      .page-ct-hub .decade .block {
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.04); /* ほんの少し軽く */
        margin-bottom: 8px; /* 下のカード層との距離を調整 */
        max-width: 760px;
        margin-left: auto;
        margin-right: auto;
      }
      .page-ct-hub .decade .table-wrap {
        overflow-x: auto;
      }

      .page-ct-hub .decade .decade-tbl {
        min-width: 0;
        width: 100%;
        table-layout: fixed;
      }

      .page-ct-hub .decade .decade-tbl th:first-child,
      .page-ct-hub .decade .decade-tbl td:first-child {
        width: auto;
      }

      .page-ct-hub .decade .decade-tbl th.num,
      .page-ct-hub .decade .decade-tbl td.num {
        width: 96px;
        text-align: center;
        white-space: nowrap;
      }

      .page-ct-hub .decade .decade-tbl thead th.num {
        text-align: center;
      }

      .page-ct-hub .sec-title {
        font-size: 17px;
        font-weight: 900;
      }

      /* section titles */
      .page-ct-hub .sec-title {
        margin: 6px 0 8px;
        margin-top: 12px;
        font-size: 16px;
        font-weight: 850;
        color: var(--color-club);
      }

      /* blocks / tables */
      .page-ct-hub .block {
        background: #fff;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 14px;
        padding: 12px;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.05);
        margin-bottom: 14px;
      }

      .page-ct-hub .table-wrap {
        overflow: auto;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 12px;
        background: #fff;
      }

      .page-ct-hub .tbl {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        min-width: 520px;
      }

      .page-ct-hub .tbl thead th {
        position: sticky;
        top: 0;
        background: color-mix(in srgb, var(--color-club) 14%, white);
        border-bottom: 1px solid rgba(0, 0, 0, 0.08);
        font-size: 12px;
        font-weight: 800;
        text-align: left;
        padding: 10px 10px;
        white-space: nowrap;
        z-index: 3;
      }

      .page-ct-hub .tbl tbody td {
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
        padding: 10px 10px;
        font-size: 13px;
        white-space: nowrap;
        vertical-align: middle;
      }

      .page-ct-hub .tbl tbody tr:hover td {
        background: rgba(0, 0, 0, 0.02);
      }

      .page-ct-hub .tbl .num {
        text-align: center;
        font-variant-numeric: tabular-nums;
        width: 100px;
      }

      /* cards */
      .page-ct-hub .cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 24px;
        border-top: 4px solid var(--color-club);
        padding-top: 12px;
      }
      @media (max-width: 1100px) {
        .page-ct-hub .cards {
          grid-template-columns: repeat(3, 1fr);
        }
      }
      @media (max-width: 820px) {
        .page-ct-hub .cards {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 560px) {
        .page-ct-hub .cards {
          grid-template-columns: 1fr;
        }
      }

      .page-ct-hub .card {
        display: block;
        text-decoration: none;
        color: inherit;
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: #fff;
        border-radius: 14px;
        padding: 10px 12px 10px;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
        transition:
          transform 0.08s ease,
          box-shadow 0.08s ease;
        min-height: 0;
      }
      .page-ct-hub .card:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.08);
