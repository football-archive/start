---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import fs from "node:fs";
import path from "node:path";
import { parseCsv } from "../../../lib/csvSimple";
import { STRONG_CLUBS } from "../../../lib/strongClubs";

type Row = {
  club_key: string;
  club_name_ja: string;
  league_key: string;
  display_tier?: string;
  league_titles_all_time?: string;
  notes?: string;
};

function readCsv(fileName: string) {
  const p = path.join(process.cwd(), "src", "data", fileName);
  const text = fs.readFileSync(p, "utf-8");
  return parseCsv(text);
}

function toTier(v: any) {
  const n = Number(String(v ?? "").trim());
  return Number.isFinite(n) ? n : 0;
}

function toNum(v: any) {
  const t = String(v ?? "").trim();
  if (!t) return null;
  const n = Number(t);
  return Number.isFinite(n) ? n : null;
}

const all: Row[] = readCsv("ct_master.csv").map((r: any) => ({
  club_key: String(r.club_key ?? "").trim(),
  club_name_ja: String(r.club_name_ja ?? "").trim(),
  league_key: String(r.league_key ?? "").trim(),
  display_tier: String(r.display_tier ?? "").trim(),
  league_titles_all_time: String(r.league_titles_all_time ?? "").trim(),
  notes: String(r.notes ?? "").trim(),
}));

/* 並び順（libの順） */
const order = new Map(STRONG_CLUBS.map((k, i) => [k, i]));

const items = all
  .filter((r) => r.club_key)
  .filter((r) => order.has(r.club_key))
  .sort((a, b) => order.get(a.club_key)! - order.get(b.club_key)!);

const tier1 = items.filter((r) => toTier(r.display_tier) === 1);
const tier2 = items.filter((r) => toTier(r.display_tier) === 2);
---

<BaseLayout
  title="クラブのあゆみ"
  description="欧州強豪クラブの歴史を、年代・黄金期・リーグ制覇などから振り返るアーカイブ。"
  showPageHeader={true}
  bodyClass="page-club"
  crumbs={[
    { label: "トップ", href: "/" },
    { label: "クラブ", href: "/clubs" },
    { label: "クラブのあゆみ" },
  ]}
>
  <main style="padding:16px">
    <h1>クラブのあゆみ</h1>

    <p class="lead">
      欧州強豪クラブの歴史を、年代・黄金期・リーグ制覇・当時のメンバーで振り返ります。
    </p>

    <h2 class="sec">歴史的強豪クラブ</h2>
    <div class="grid">
      {
        tier1.map((c) => {
          const titles = toNum(c.league_titles_all_time);
          const note = (c.notes ?? "").trim();
          return (
            <a class="card" href={`/clubs/history/${c.club_key}`}>
              <div class="top">
                <div class="name">{c.club_name_ja}</div>
                <div class="badges">
                  <span class="badge win">
                    リーグ優勝 {titles === null ? "-" : titles}
                  </span>
                </div>
              </div>

              <div class="sub">
                <span class={`intro ${note ? "theme" : "muted"}`}>
                  {note || "データ準備中"}
                </span>
              </div>
            </a>
          );
        })
      }
    </div>

    <h2 class="sec">強豪に迫る名門クラブ</h2>
    <div class="grid">
      {
        tier2.map((c) => {
          const titles = toNum(c.league_titles_all_time);
          const note = (c.notes ?? "").trim();
          return (
            <a class="card" href={`/clubs/history/${c.club_key}`}>
              <div class="top">
                <div class="name">{c.club_name_ja}</div>
                <div class="badges">
                  <span class="badge win">
                    リーグ優勝 {titles === null ? "-" : titles}
                  </span>
                </div>
              </div>

              <div class="sub">
                <span class={`intro ${note ? "theme" : "muted"}`}>
                  {note || "データ準備中"}
                </span>
              </div>
            </a>
          );
        })
      }
    </div>
  </main>

  <style>
    /* ===== Club Legends (match nt-legends) ===== */
    .lead {
      margin: 6px 0 12px;
      color: #374151;
      font-size: 14px;
      line-height: 1.7;
    }

    .sec {
      margin: 16px 0 10px;
      font-size: 16px;
      font-weight: 850;
      color: var(--theme-color);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin: 0 0 20px;
    }
    @media (max-width: 980px) {
      .grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 560px) {
      .grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    /* ===== Card (compact) ===== */
    .card {
      display: block;
      border: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: 14px;
      background: #fff;
      padding: 10px 10px 9px;
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
      min-width: 0;
      text-decoration: none;
      color: inherit;
    }
    .card:hover {
      box-shadow: 0 10px 22px rgba(0, 0, 0, 0.08);
      transform: translateY(-1px);
      transition: 0.08s ease;
      background: var(--theme-soft-bg);
      border-color: var(--theme-soft-border);
    }

    .top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 6px;
    }

    .name {
      font-size: 15px;
      font-weight: 900;
      letter-spacing: 0.2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      min-width: 0;
    }

    /* バッジ領域：縮みすぎ防止（sub消しても崩れない） */
    .badges {
      display: flex;
      gap: 6px;
      flex-wrap: nowrap;
      justify-content: flex-end;
      flex-shrink: 0;
    }

    /* 代表と同じpill */
    .badge {
      font-size: 12px;
      font-weight: 900;
      padding: 2px 7px;
      border-radius: 999px;
      border: 1px solid rgba(0, 0, 0, 0.08);
      background: #fafafa;
      white-space: nowrap;
      line-height: 1.2;
    }

    /* “優勝”はテーマ色 */
    .badge.win {
      background: color-mix(in srgb, var(--theme-color) 14%, white);
      border-color: color-mix(in srgb, var(--theme-color) 25%, transparent);
      color: #111;   /* ←追加 */
    }

    .sub {
      font-size: 12px;
      margin-bottom: 6px;
      min-height: 1.2em;
    }

    /* notes行（intro） */
    .intro {
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      line-height: 1.2;
    }
    .intro.muted {
      opacity: 0.65;
      color: #111;
    }
    .intro.theme {
      color: var(--theme-color);
      font-weight: 850;
    }
  </style>
</BaseLayout>
