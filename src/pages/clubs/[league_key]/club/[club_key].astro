---
import { loadClubSquads } from "../../../../lib/clubSquads";
import { clubUrl } from "../../../../lib/urls";

export async function getStaticPaths() {
  const rows = loadClubSquads();

  const keys = new Set(
    rows
      .map((r) => {
        const league_key = String(r.league_key ?? "").trim();
        const club_key = String(r.club_key ?? "").trim();
        if (!league_key || !club_key) return "";
        return `${league_key}|||${club_key}`;
      })
      .filter(Boolean),
  );

  return [...keys].map((k) => {
    const [league_key, club_key] = k.split("|||");
    return { params: { league_key, club_key } };
  });
}

const league_key = String(Astro.params.league_key ?? "").trim();
const club_key = String(Astro.params.club_key ?? "").trim();

const rows = loadClubSquads().filter(
  (r) => String(r.league_key ?? "").trim() === league_key &&
       String(r.club_key ?? "").trim() === club_key,
);

const seasonStart = (s: string) => {
  const m = String(s ?? "").trim().match(/^(\d{4})/);
  return m ? Number(m[1]) : 0;
};

const url = new URL(Astro.request.url);
const seasonParam = String(url.searchParams.get("season") ?? "").trim();

const seasons = Array.from(
  new Set(rows.map((r) => String(r.season ?? "").trim()).filter(Boolean))
).sort((a, b) => seasonStart(b) - seasonStart(a));

const targetSeason =
  seasonParam && seasons.includes(seasonParam)
    ? seasonParam
    : seasons[0] ?? "";

const href = targetSeason
  ? clubUrl({
      leagueKey: league_key,
      clubKey: club_key,
      season: targetSeason as any,
    })
  : `/clubs/${encodeURIComponent(league_key)}/`;

return Astro.redirect(href, 301);
---