---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";

import { loadClubSquads, sortClubRoster } from "../../../../../lib/clubSquads";
import { loadClubMaster } from "../../../../../lib/clubMaster";
import { loadLeagueMaster } from "../../../../../lib/leagueMaster";

import { loadCallups } from "../../../../../lib/callups";
import { buildRepLabelFromCallups } from "../../../../../lib/repCandidate";

import RosterView from "../../../../../components/RosterView.astro";

import { buildClubColumns } from "../../../../../lib/rosterColumns";
import { toYMD } from "../../../../../lib/rosterFormat";
import { seasonShort } from "../../../../../lib/seasonFormat";

// ★ クラブ“あゆみ”用：シーズンメタ（順位/監督など）
import {
  loadCtSeasonMeta,
  findCtSeasonMeta,
} from "../../../../../lib/ctSeasonMeta";

import { loadLeagueStandings } from "../../../../../lib/leagueStandings";

import { buildRepHistoryLinksFromCallups } from "../../../../../lib/repCandidate";

// ★ country master 読み込み用
import { parseCsv } from "../../../../../lib/csvSimple";
import fs from "node:fs";
import path from "node:path";

import { clubUrl } from "../../../../../lib/urls";

// --------------------
// getStaticPaths：keyで生成
// --------------------
export async function getStaticPaths() {
  const rows = loadClubSquads();

  const keys = new Set(
    rows
      .map((r) => {
        const league_key = String(r.league_key ?? "").trim();
        const club_key = String(r.club_key ?? "").trim();
        const season = String(r.season ?? "").trim();

        if (!league_key || !club_key || !season) return "";
        return `${league_key}|||${club_key}|||${season}`;
      })
      .filter(Boolean),
  );

  return [...keys].map((k) => {
    const [league_key, club_key, season] = k.split("|||");
    return {
      params: { league_key, club_key, season },
    };
  });
}

const league_key = Astro.params.league_key!;
const club_key = Astro.params.club_key!;
const routeSeason = String(Astro.params.season ?? "").trim();

// --------------------
// master 参照：表示名（日本語）をここで確定
// --------------------
const clubMaster = loadClubMaster();
const leagueMaster = loadLeagueMaster();

const clubInfo = clubMaster.find((c) => c.club_key === club_key);
const leagueInfo = leagueMaster.find((l) => l.league_key === league_key);

const clubInMaster = !!clubInfo;
const leagueInMaster = !!leagueInfo;

const clubLabel = clubInfo?.club_display_ja ?? club_key;
const leagueLabel = leagueInfo?.league_display_ja ?? league_key;
const leagueTopPath = `/clubs/${encodeURIComponent(league_key)}/`;
const clubTopPath = `/clubs/${encodeURIComponent(league_key)}/club/${encodeURIComponent(club_key)}/`;
const leagueSeasonPath = (seasonStr: string) =>
  `/clubs/${encodeURIComponent(league_key)}/${encodeURIComponent(
    String(seasonStr ?? "").trim(),
  )}/`;

// --------------------
// country master
// --------------------
type CountryMasterRow = {
  country_key: string;
  country_name_ja: string;
  country_name_en: string;
  continent: string;
  confederation: string;
};

function readCsv(fileName: string) {
  const p = path.join(process.cwd(), "src", "data", fileName);
  const text = fs.readFileSync(p, "utf-8");
  return parseCsv(text);
}

const countryMaster: CountryMasterRow[] = readCsv("country_master.csv").map(
  (r: any) => ({
    country_key: String(r.country_key ?? "").trim(),
    country_name_ja: String(r.country_name_ja ?? "").trim(),
    country_name_en: String(r.country_name_en ?? "").trim(),
    continent: String(r.continent ?? "").trim(),
    confederation: String(r.confederation ?? "").trim(),
  }),
);

type ClubLineupImageRow = {
  season: string;
  league_key: string;
  club_key: string;
  formation: string;
  image: string;
};

const clubLineupImages: ClubLineupImageRow[] = readCsv(
  "club_lineup_images.csv",
).map((r: any) => ({
  season: String(r.season ?? "").trim(),
  league_key: String(r.league_key ?? "")
    .trim()
    .toLowerCase(),
  club_key: String(r.club_key ?? "")
    .trim()
    .toLowerCase(),
  formation: String(r.formation ?? "").trim(),
  image: String(r.image ?? "").trim(),
}));

const normCountry = (s: any) =>
  String(s ?? "")
    .trim()
    .toLowerCase();

const countryToContinent = new Map<string, string>();
for (const c of countryMaster) {
  if (c.country_name_en)
    countryToContinent.set(normCountry(c.country_name_en), c.continent);
  if (c.country_name_ja)
    countryToContinent.set(normCountry(c.country_name_ja), c.continent);
  if (c.country_key)
    countryToContinent.set(normCountry(c.country_key), c.continent);
}

const continentJa = (c: string) => {
  switch (String(c ?? "").trim()) {
    case "Europe":
      return "欧州";
    case "South America":
      return "南米";
    case "North America":
    case "Central America":
    case "North/Central America":
    case "North & Central America":
      return "北中米";
    case "Africa":
      return "アフリカ";
    case "Asia":
      return "アジア";
    case "Oceania":
      return "オセアニア";
    default:
      return "";
  }
};

const firstNationality = (s: any) =>
  String(s ?? "")
    .split(/[|,/、]/)
    .map((x) => String(x ?? "").trim())
    .filter(Boolean)[0] ?? "";

const calcAge = (birth: string, base: Date) => {
  if (!birth) return null;
  const d = new Date(String(birth).replace(/\//g, "-"));
  if (isNaN(d.getTime())) return null;

  let age = base.getFullYear() - d.getFullYear();
  const m = base.getMonth() - d.getMonth();
  if (m < 0 || (m === 0 && base.getDate() < d.getDate())) age--;
  return age;
};

const buildClubStatsLine = (
  rows: any[],
  snapshot: string,
  enabled: boolean,
) => {
  if (!enabled || !rows.length) {
    return {
      avgAgeText: "",
      continentText: "",
    };
  }

  const base = new Date(String(snapshot || "").replace(/\//g, "-"));
  if (isNaN(base.getTime())) {
    return {
      avgAgeText: "",
      continentText: "",
    };
  }

  const ages = rows
    .map((r) => calcAge(String(r.birth_date ?? ""), base))
    .filter((a) => a !== null) as number[];

  const avgAge =
    ages.length > 0
      ? (ages.reduce((a, b) => a + b, 0) / ages.length).toFixed(1)
      : "";

  const counts: Record<string, number> = {};
  for (const r of rows) {
    const nat = firstNationality(r.nationality);
    if (!nat) continue;

    const continent = countryToContinent.get(normCountry(nat));
    if (!continent) continue;

    const label = continentJa(continent);
    if (!label) continue;

    counts[label] = (counts[label] ?? 0) + 1;
  }

  const order = ["欧州", "南米", "北中米", "アフリカ", "アジア", "オセアニア"];
  const continentBody = order
    .map((label) => (counts[label] ? `${label}: ${counts[label]}` : null))
    .filter(Boolean)
    .join(" / ");

  return {
    avgAgeText: avgAge ? `平均年齢：${avgAge}歳` : "",
    continentText: continentBody ? `大陸別：${continentBody}` : "",
  };
};

// --------------------
// roster：keyで抽出（window/snapshot/season を扱う）
// --------------------
const allClubSquadRows = loadClubSquads();

const allRows = allClubSquadRows.filter(
  (r) => r.league_key === league_key && r.club_key === club_key,
);

// window 正規化（想定外は summer 扱いで落ちないようにする）
const normWindow = (v: any): "summer" | "winter" => {
  const s = String(v ?? "")
    .trim()
    .toLowerCase();
  return s === "winter" ? "winter" : "summer";
};

// season の “新しさ” 比較用（"2025-26" → 2025）
const seasonStart = (seasonStr: any) => {
  const s = String(seasonStr ?? "").trim();
  const m = s.match(/^(\d{4})/);
  return m ? Number(m[1]) : 0;
};

// snapshot の max（window内で最新1枚を作る）
const maxSnapIn = (rows: any[]) => {
  let max = "";
  for (const r of rows) {
    const s = toYMD(String(r.snapshot_date ?? ""));
    if (s && s > max) max = s;
  }
  return max;
};

// ---- season：候補（全件）＋URL選択 ----
const url = new URL(Astro.request.url);
const qWin = String(url.searchParams.get("window") ?? "").toLowerCase();

// season候補（全シーズン）
const seasonCandidates = Array.from(
  new Set(allRows.map((r) => String(r.season ?? "").trim()).filter(Boolean)),
).sort((a, b) => seasonStart(b) - seasonStart(a));

// 「最新season」= 初期表示に使う（静的HTML）
const latestSeason = seasonCandidates[0] ?? "";
const currentClubSeason = "2025-26"; // 手動更新：最新シーズンに合わせて切替
const isCurrentSeason = (season: string) =>
  String(season ?? "").trim() === currentClubSeason;

// seasonごとに summer/winter の「最新スナップ」だけ残してロスター化
type SeasonPack = {
  season: string;
  hasSummer: boolean;
  hasWinter: boolean;
  defaultWindow: "summer" | "winter";
  summerUpdated: string;
  winterUpdated: string;
  rosterSummer: any[];
  rosterWinter: any[];
  starRowsSummer: any[];
  starRowsWinter: any[];
  isLatestViewSummer: boolean;
  isLatestViewWinter: boolean;
  statsSummer: {
    avgAgeText: string;
    continentText: string;
  };
  statsWinter: {
    avgAgeText: string;
    continentText: string;
  };
};

const seasonPacks: SeasonPack[] = seasonCandidates.map((s) => {
  const rowsForSeason = allRows.filter(
    (r) => String(r.season ?? "").trim() === s,
  );

  const summerRows = rowsForSeason.filter(
    (r) => normWindow(r.window) === "summer",
  );
  const winterRows = rowsForSeason.filter(
    (r) => normWindow(r.window) === "winter",
  );

  const summerSnapMax = maxSnapIn(summerRows);
  const winterSnapMax = maxSnapIn(winterRows);

  const rosterSummer = sortClubRoster(
    summerRows.filter(
      (r) => toYMD(String(r.snapshot_date ?? "")) === summerSnapMax,
    ),
  );
  const rosterWinter = sortClubRoster(
    winterRows.filter(
      (r) => toYMD(String(r.snapshot_date ?? "")) === winterSnapMax,
    ),
  );

  const hasSummer = rosterSummer.length > 0;
  const hasWinter = rosterWinter.length > 0;

  // デフォルト window：winter 優先（そのseason内で）
  const defaultWindow: "summer" | "winter" = hasWinter ? "winter" : "summer";

  // そのseasonの「最新view」判定（年齢など）
  const latestWindow = defaultWindow;
  const isLatestViewSummer = latestWindow === "summer" && hasSummer;
  const isLatestViewWinter = latestWindow === "winter" && hasWinter;

  const summerUpdated = summerSnapMax ? toYMD(summerSnapMax) : "";
  const winterUpdated = winterSnapMax ? toYMD(winterSnapMax) : "";

  const starRowsSummer = rosterSummer
    .filter((r) => String((r as any).is_star ?? "").trim() === "1")
    .slice(0, 3);

  const starRowsWinter = rosterWinter
    .filter((r) => String((r as any).is_star ?? "").trim() === "1")
    .slice(0, 3);

  const showStats = isCurrentSeason(s);

  const statsSummer = buildClubStatsLine(
    rosterSummer,
    summerUpdated,
    showStats,
  );
  const statsWinter = buildClubStatsLine(
    rosterWinter,
    winterUpdated,
    showStats,
  );

  return {
    season: s,
    hasSummer,
    hasWinter,
    defaultWindow,
    summerUpdated,
    winterUpdated,
    rosterSummer,
    rosterWinter,
    starRowsSummer,
    starRowsWinter,
    isLatestViewSummer,
    isLatestViewWinter,
    statsSummer,
    statsWinter,
  };
});

const statNum = (v: any) => {
  const n = Number(v);
  return Number.isFinite(n) ? n : 0;
};

const hasGoalStats = (rows: any[]) => rows.some((r) => statNum(r.goals) > 0);

// 全体としてロスターがあるか
const hasRoster = seasonPacks.some((p) => p.hasSummer || p.hasWinter);

const leagueStandings = loadLeagueStandings();
const hasLeagueStandingSeason = (seasonStr: string) =>
  leagueStandings.some(
    (r) =>
      r.league_key === league_key &&
      String(r.season ?? "").trim() === String(seasonStr ?? "").trim(),
  );

const prevSeasonOf = (seasonStr: string) => {
  const s = String(seasonStr ?? "").trim();
  const m = s.match(/^(\d{4})-(\d{2})$/);
  if (!m) return "";

  const start = Number(m[1]);
  const prevStart = start - 1;
  const prevEnd2 = ((prevStart + 1) % 100).toString().padStart(2, "0");
  return `${prevStart}-${prevEnd2}`;
};

const getStandingSourceSeason = (seasonStr: string) => {
  const current = String(seasonStr ?? "").trim();

  const hasCurrent = leagueStandings.some(
    (r) => r.league_key === league_key && r.season === current,
  );
  if (hasCurrent) return current;

  // 現行シーズンだけ、無ければ前シーズン参照
  if (isCurrentSeason(current)) {
    const prev = prevSeasonOf(current);
    const hasPrev = leagueStandings.some(
      (r) => r.league_key === league_key && r.season === prev,
    );
    if (hasPrev) return prev;
  }

  return "";
};

const hasClubSeason = (targetClubKey: string, seasonStr: string) =>
  allClubSquadRows.some(
    (r) =>
      r.league_key === league_key &&
      r.club_key === targetClubKey &&
      String(r.season ?? "").trim() === String(seasonStr ?? "").trim(),
  );

const getRecommendedLeagueClubs = (seasonStr: string) => {
  const sourceSeason = getStandingSourceSeason(seasonStr);

  if (!sourceSeason) {
    return {
      sourceSeason: "",
      sourceLabel: "",
      items: [] as { club_key: string; label: string; href: string }[],
    };
  }

  const rows = leagueStandings
    .filter((r) => r.league_key === league_key && r.season === sourceSeason)
    .sort((a, b) => a.rank - b.rank);

  const items = rows
    .filter((r) => r.club_key !== club_key)
    .filter((r) => hasClubSeason(r.club_key, seasonStr))
    .map((r) => {
      const m = clubMaster.find((c) => c.club_key === r.club_key);

      return {
        club_key: r.club_key,
        label: m?.club_display_ja ?? r.club_key,
        href: clubUrl({
          leagueKey: league_key,
          clubKey: r.club_key,
          season: seasonStr as any,
        }),
      };
    })
    .slice(0, 5);

  const sourceLabel =
    sourceSeason === seasonStr ? "同リーグ上位クラブ" : "前シーズン上位クラブ";

  return {
    sourceSeason,
    sourceLabel,
    items,
  };
};

// --------------------
// クラブ“あゆみ”メタ（順位/監督など）：ct_season_meta.csv 参照
// --------------------
const ctSeasonMetaAll = loadCtSeasonMeta();

const seasonLong = (seasonStr: string): string => {
  const s = String(seasonStr ?? "").trim();
  return s ? `${s}シーズン` : "";
};

const ctMetaParts = (seasonStr: string) => {
  const meta = findCtSeasonMeta(ctSeasonMetaAll, {
    season: seasonStr,
    league_key,
    club_key,
  });
  if (!meta) {
    return {
      rank: "",
      coach: "",
      line: "",
    };
  }

  const rank = String(meta.rank_ja ?? "").trim();
  const coach = String(meta.coach_ja ?? "").trim();
  const line = [rank, coach ? `${coach}` : ""].filter(Boolean).join(" ｜ ");

  return {
    rank,
    coach,
    line,
  };
};

const initialSeason =
  routeSeason && seasonCandidates.includes(routeSeason)
    ? routeSeason
    : latestSeason;
const initialPack = seasonPacks.find((p) => p.season === initialSeason);

const defaultWindow = initialPack?.defaultWindow ?? "summer";

const initialWindow =
  qWin === "winter" || qWin === "summer" ? (qWin as any) : defaultWindow;

const initialSeasonIndex = seasonCandidates.findIndex(
  (s) => s === initialSeason,
);

const initialPrevSeason =
  initialSeasonIndex >= 0 && initialSeasonIndex < seasonCandidates.length - 1
    ? seasonCandidates[initialSeasonIndex + 1]
    : "";

const initialNextSeason =
  initialSeasonIndex > 0 ? seasonCandidates[initialSeasonIndex - 1] : "";

// --------------------
// ✅ SEO：title / description / heading（型を統一）
// --------------------
const season = initialSeason;
const clubLineupRow = clubLineupImages.find(
  (r) =>
    r.season === String(initialSeason ?? "").trim() &&
    r.league_key ===
      String(league_key ?? "")
        .trim()
        .toLowerCase() &&
    r.club_key ===
      String(club_key ?? "")
        .trim()
        .toLowerCase(),
);

const clubLineupImageSrc = clubLineupRow?.image
  ? `/images/lineups/${clubLineupRow.image}`
  : "";

const clubLineupFormation = String(clubLineupRow?.formation ?? "").trim();

const clubLineupAlt = clubLineupFormation
  ? `${clubLabel} ${seasonShort(initialSeason)} 想定スタメン ${clubLineupFormation}`
  : `${clubLabel} ${seasonShort(initialSeason)} 想定スタメン`;

const hasClubLineupImage = !!clubLineupImageSrc;

const seasonLongLabel = season ? seasonLong(season) : "";
const seasonShortLabel = season ? seasonShort(season) : "";

// SEOタイトル
const title = season
  ? `${clubLabel} ${seasonShortLabel}メンバー一覧｜背番号・ゴール・アシスト・代表歴｜${leagueLabel}`
  : `${clubLabel} メンバー一覧｜背番号・ゴール・アシスト・代表歴｜${leagueLabel}`;

// meta description
const description = season
  ? `${clubLabel}の${seasonLongLabel}所属選手一覧。背番号・ポジション・国籍・加入日・代表歴・出場数・ゴール・アシスト・年齢・身長を掲載。想定スタメンや注目選手、過去シーズンのメンバー構成も確認できます。`
  : `${clubLabel}の所属選手一覧。背番号・ポジション・国籍・加入日・代表歴・出場数・ゴール・アシスト・年齢・身長を掲載。想定スタメンや注目選手、過去シーズンのメンバー構成も確認できます。`;

// BaseLayout側の見出し
const heading = season
  ? `${clubLabel} ${seasonShortLabel}メンバー一覧`
  : `${clubLabel} メンバー一覧`;

// ===== 代表（候補）表示：WC2026の最新スナップショットだけを参照 =====
const callups = loadCallups();
const {
  repLabel,
  repLinks,
  maxSnapshot: repMaxSnapshot,
} = buildRepLabelFromCallups(callups, { competition: "WC", edition: 2026 });

const repHistoryLinks = buildRepHistoryLinksFromCallups(callups, {
  competition: "WC",
  excludeEdition: 2026, // WC2026 は既に下段で出てるので除外
  max: 6,
});

const columnsBySeason: Record<string, { summer: any; winter: any }> = {};
for (const p of seasonPacks) {
  columnsBySeason[p.season] = {
    summer: buildClubColumns({
      isLatestView: p.isLatestViewSummer,
      repLabel,
      repLinks,
      repHistoryLinks,
      showStats: false,
    }),
    winter: buildClubColumns({
      isLatestView: p.isLatestViewWinter,
      repLabel,
      repLinks,
      repHistoryLinks,
      showStats: p.hasWinter && hasGoalStats(p.rosterWinter),
    }),
  };
}

// pills 用：公開対象リーグのみ + sort_rank順
const leaguePills = leagueMaster
  .filter((l: any) => (l.is_public ?? true) === true)
  .filter((l) => (l.league_key ?? "").trim().length > 0)
  .map((l: any) => {
    const n = Number(String(l.sort_rank ?? "").trim());
    const sort_rank = Number.isFinite(n) ? n : 999;

    return {
      key: l.league_key,
      label: l.league_display_ja || l.league_key,
      sort_rank,
    };
  })
  .sort((a, b) => {
    if (a.sort_rank !== b.sort_rank) return a.sort_rank - b.sort_rank;
    return a.label.localeCompare(b.label, "ja");
  });

// 検索テキスト共通
const searchTextFn = (r: any) =>
  `${r.name_ja ?? ""} ${r.name_en ?? ""} ${repLabel(r) ?? ""} ${r.nationality ?? ""}`.trim();

// 備考欄の new / out に応じて選手行を色分け
const clubRosterRowClass = (r: any) => {
  const note = String(r.notes ?? "")
    .trim()
    .toLowerCase();

  if (note.includes("new")) return "row-new";
  if (note.includes("out")) return "row-out";

  return "";
};

const initialRec = getRecommendedLeagueClubs(initialSeason);

const topPastSeasons = seasonCandidates
  .filter((s) => seasonStart(s) < seasonStart(initialSeason))
  .slice(0, 6);

const topLeagueClubLinks = initialRec.items;

const topOtherLeaguePills = leaguePills.filter((p) => p.key !== league_key);
---

<BaseLayout
  title={title}
  description={description}
  bodyClass="page-club"
  bodyStyle="margin:0; font-family: system-ui;"
  showPageHeader={true}
  crumbs={[
    { label: "トップ", href: "/" },
    { label: "クラブ", href: "/clubs/" },
    { label: leagueLabel, href: leagueTopPath },
    { label: clubLabel, href: clubTopPath },
    { label: season },
  ]}
  heading={heading}
>
  {
    seasonPacks.map((p) => {
      const meta = ctMetaParts(p.season);

      const seasonIndex = seasonCandidates.findIndex((s) => s === p.season);
      const prevSeason =
        seasonIndex >= 0 && seasonIndex < seasonCandidates.length - 1
          ? seasonCandidates[seasonIndex + 1]
          : "";
      const nextSeason =
        seasonIndex > 0 ? seasonCandidates[seasonIndex - 1] : "";

      return (
        <div
          class="club-hero"
          data-title-season={p.season}
          style={`display:${p.season === initialSeason ? "" : "none"}`}
        >
          <h2 class="club-hero-title">
            {clubLabel} {seasonLong(p.season)}{" "}
            メンバー一覧｜背番号・ゴール・アシスト・代表歴
          </h2>

          <p class="hero-desc">
            {clubLabel}の{seasonLong(p.season)}
             所属選手一覧。背番号・ポジション・国籍・加入日・代表歴・出場数・ゴール・アシスト・年齢・身長を掲載。
            <br />
            📢 背番号は発表され次第、更新します。（直近の情報を暫定で表示）
            <br />
            🔥 想定スタメンや注目選手、過去シーズン当時の代表招集歴も確認できます。
          </p>
        </div>
      );
    })
  }

  {
    seasonPacks.map((p) => {
      const meta = ctMetaParts(p.season);

      return (
        <div
          class="club-meta-block"
          data-meta-season={p.season}
          style={`display:${p.season === initialSeason ? "" : "none"}`}
        >
{(meta.rank || meta.coach) && (
  <div class="club-meta-row">
    {meta.rank ? (
      hasLeagueStandingSeason(p.season) ? (
        <a
          class="club-rank-link"
          href={leagueSeasonPath(p.season)}
          title={`${leagueLabel}${seasonShort(p.season)}順位表を見る`}
        >
          {meta.rank}
        </a>
      ) : (
        meta.rank
      )
    ) : (
      "—"
    )}

    {meta.coach ? ` ｜ ${meta.coach}` : ""}
  </div>
)}

          {p.statsSummer.avgAgeText || p.statsSummer.continentText ? (
            <>
