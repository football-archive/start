  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      try {
        const lineupOpenBtn = document.getElementById("club-lineup-open");
        const lineupCloseBtn = document.getElementById("club-lineup-close");
        const lineupModal = document.getElementById("club-lineup-modal");

        if (lineupOpenBtn && lineupCloseBtn && lineupModal) {
          lineupOpenBtn.addEventListener("click", () => {
            if (typeof gtag === "function") {
              gtag("event", "lineup_click", {
                event_category: "engagement",
                event_label: document.title,
                lineup_type: "club",
              });
            }

            if (typeof lineupModal.showModal === "function") {
              lineupModal.showModal();
              document.body.classList.add("is-lineup-modal-open");
            }
          });

          lineupCloseBtn.addEventListener("click", (e) => {
            e.preventDefault();
            e.stopPropagation();

            if (typeof lineupModal.close === "function") {
              lineupModal.close();
              document.body.classList.remove("is-lineup-modal-open");
            }
          });

          lineupModal.addEventListener("click", (e) => {
            const rect = lineupModal.getBoundingClientRect();

            const isInDialog =
              rect.top <= e.clientY &&
              e.clientY <= rect.top + rect.height &&
              rect.left <= e.clientX &&
              e.clientX <= rect.left + rect.width;

            if (!isInDialog && typeof lineupModal.close === "function") {
              lineupModal.close();
              document.body.classList.remove("is-lineup-modal-open");
            }
          });

          lineupModal.addEventListener("close", () => {
            document.body.classList.remove("is-lineup-modal-open");
          });
        }

        const windowRoot = document.querySelector(".window-toggle");
        if (!windowRoot) return;

        const windowBtns = Array.from(
          windowRoot.querySelectorAll("button[data-window]"),
        );

        const sections = Array.from(
          document.querySelectorAll("section[data-window][data-season]"),
        );
        const updatedDates = Array.from(
          document.querySelectorAll("[data-updated][data-season]"),
        );
        const titleBlocks = Array.from(
          document.querySelectorAll("[data-title-season]"),
        );
        const starSections = Array.from(
          document.querySelectorAll("[data-star-window][data-season]"),
        );
        const statLines = Array.from(
          document.querySelectorAll("[data-stats-window][data-season]"),
        );

        const recoSections = Array.from(
          document.querySelectorAll("[data-reco-window][data-season]"),
        );

        const seasonRecoSections = Array.from(
          document.querySelectorAll("[data-season-reco-window][data-season]"),
        );

        const seasonNavBlocks = Array.from(
          document.querySelectorAll("[data-nav-season]"),
        );

        const metaBlocks = Array.from(
          document.querySelectorAll("[data-meta-season]"),
        );

        const packs = JSON.parse(
          windowRoot.getAttribute("data-season-packs") || "[]",
        );

        const params = new URLSearchParams(location.search);
        const qWin = (params.get("window") || "").toLowerCase();

        const currentSeason = (
          windowRoot.getAttribute("data-current-season") || ""
        ).trim();

        const initialSeason =
          currentSeason && packs.some((p) => p.season === currentSeason)
            ? currentSeason
            : packs[0]?.season || "";

        function findPack(season) {
          return packs.find((p) => p.season === season);
        }

        function setWindowAvailability(season) {
          const p = findPack(season);
          const hasSummer = !!p?.hasSummer;
          const hasWinter = !!p?.hasWinter;

          windowBtns.forEach((b) => {
            const w = b.getAttribute("data-window");
            if (w === "summer") b.disabled = !hasSummer;
            if (w === "winter") b.disabled = !hasWinter;
            b.title = b.disabled ? "データなし" : "";
          });

          return p?.defaultWindow || "summer";
        }

        function setActive(season, win) {
          sections.forEach((sec) => {
            const s = sec.getAttribute("data-season");
            const w = sec.getAttribute("data-window");
            sec.style.display = s === season && w === win ? "" : "none";
          });

          updatedDates.forEach((el) => {
            const s = el.getAttribute("data-season");
            const w = el.getAttribute("data-updated");
            el.style.display = s === season && w === win ? "" : "none";
          });

          titleBlocks.forEach((el) => {
            const s = el.getAttribute("data-title-season");
            el.style.display = s === season ? "" : "none";
          });

          seasonNavBlocks.forEach((el) => {
            const s = el.getAttribute("data-nav-season");
            el.style.display = s === season ? "" : "none";
          });

          metaBlocks.forEach((el) => {
            const s = el.getAttribute("data-meta-season");
            el.style.display = s === season ? "" : "none";
          });

          starSections.forEach((sec) => {
            const s = sec.getAttribute("data-season");
            const w = sec.getAttribute("data-star-window");
            sec.style.display = s === season && w === win ? "" : "none";
          });

          statLines.forEach((el) => {
            const s = el.getAttribute("data-season");
            const w = el.getAttribute("data-stats-window");
            el.style.display = s === season && w === win ? "" : "none";
          });

          recoSections.forEach((sec) => {
            const s = sec.getAttribute("data-season");
            const w = sec.getAttribute("data-reco-window");
            sec.style.display = s === season && w === win ? "" : "none";
          });

          windowBtns.forEach((b) => {
            b.classList.toggle(
              "is-active",
              b.getAttribute("data-window") === win,
            );
          });

          const jumpLink = document.getElementById("club-roster-jump-link");
          if (jumpLink) {
            jumpLink.setAttribute(
              "href",
              `#club-roster-${season}-${win}-section`,
            );
          }
        }

        function goToSeasonWindow(season, win) {
          location.href =
            location.pathname + `?window=${encodeURIComponent(win)}`;
        }

        const defaultWinFromSeason = setWindowAvailability(initialSeason);
        const initialWin =
          qWin === "winter" || qWin === "summer" ? qWin : defaultWinFromSeason;
        setActive(initialSeason, initialWin);

        windowBtns.forEach((b) => {
          b.addEventListener("click", () => {
            if (b.disabled) return;
            const win = b.getAttribute("data-window");
            if (!win) return;
            goToSeasonWindow(initialSeason, win);
          });
        });
      } catch (e) {
        console.error("season/window toggle init failed:", e);
      }
    });
  </script>

