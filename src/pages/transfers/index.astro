---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadTransfers } from "../../lib/transfers";

const all = loadTransfers();

const seasons = Array.from(
  new Set(all.map((x) => String(x.season || "").trim()).filter(Boolean)),
).sort((a, b) => b.localeCompare(a));

const windows = Array.from(
  new Set(all.map((x) => String(x.window || "").trim()).filter(Boolean)),
);

const latestSeason = seasons[0] ?? "2025-26";

const latestWindow = windows.includes("winter")
  ? "winter"
  : (windows[0] ?? "winter");

const latestHref =
  `/transfers/${latestSeason}/${latestWindow}/`;
---

<BaseLayout
  title="海外サッカー移籍情報｜海外サッカーDB"
  description="海外サッカー主要移籍一覧ページです。"
  bodyClass="page-transfer"
  crumbs={[
    { label: "トップ", href: "/" },
    { label: "移籍" },
  ]}
>

<h1>海外サッカー移籍情報</h1>

<p>
  最新の移籍一覧はこちら。
</p>

<p>
  <a href={latestHref}>
    {latestSeason} {latestWindow === "winter" ? "冬" : "夏"} 移籍一覧へ
  </a>
</p>

</BaseLayout>