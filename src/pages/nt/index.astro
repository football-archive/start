---
// src/pages/nt/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";

const heading = "代表";
const title = `${heading} | World Football Archive`;
const description =
  "各国代表の情報をまとめて閲覧。ワールドカップ、強豪国の歩み、日本代表など、代表コンテンツの入口ページ。";
---

<BaseLayout
  title={title}
  description={description}
  bodyClass="page-nt-portal page-wc"
  bodyStyle="margin:0; font-family: system-ui;"
  showPageHeader={true}
  crumbs={[
    { label: "トップ", href: "/" },
    { label: "代表" },
  ]}
  heading={heading}
>
  <div class="lead">
    <p>
      代表コンテンツの入口ページです。ワールドカップ2026、強豪国のW杯あゆみ、日本代表などへすぐ移動できます。
    </p>
  </div>

  <section class="grid" aria-label="代表メニュー">
    <a class="card" href="/wc/2026">
      <div class="t">FIFAワールドカップ2026</div>
      <div class="d">大会ポータル（試合日程・結果・表・ランキング）</div>
      <div class="go">開く →</div>
    </a>

    <a class="card" href="/nt/wc/legends">
      <div class="t">強豪国代表　W杯のあゆみ</div>
      <div class="d">優勝回数ランキング＋各国のW杯あゆみへ</div>
      <div class="go">開く →</div>
    </a>

    <a class="card" href="/nt/japan/wc">
      <div class="t">日本代表　W杯のあゆみ</div>
      <div class="d">歴代大会・メンバー一覧へ</div>
      <div class="go">開く →</div>
    </a>

    <div class="card is-soon" aria-disabled="true">
      <div class="t">代表一覧（準備中）</div>
      <div class="d">全代表チームの一覧・検索（将来）</div>
      <div class="go">準備中</div>
    </div>
  </section>

  <style is:global>
    .page-nt-portal .lead{
      margin:6px 0 14px;
      color:#374151;
      font-size:14px;
      line-height:1.7;
    }

    .page-nt-portal .grid{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:12px;
      margin: 0 0 22px;
    }
    @media (max-width: 820px){
      .page-nt-portal .grid{ grid-template-columns: 1fr; }
    }

    .page-nt-portal .card{
      display:block;
      border:1px solid rgba(0,0,0,0.08);
      border-radius:14px;
      background:#fff;
      padding:12px 12px 10px;
      box-shadow:0 6px 16px rgba(0,0,0,0.06);
      text-decoration:none;
      color:inherit;
    }
    .page-nt-portal .card:hover{
      transform: translateY(-1px);
      transition: 0.08s ease;
      box-shadow:0 10px 22px rgba(0,0,0,0.08);
      outline:1px solid color-mix(in srgb, var(--theme-color) 22%, transparent);
    }

    .page-nt-portal .t{
      font-size:15px;
      font-weight:900;
      margin-bottom:6px;
    }
    .page-nt-portal .d{
      font-size:13px;
      opacity:0.82;
      line-height:1.6;
      margin-bottom:8px;
    }
    .page-nt-portal .go{
      font-size:12.5px;
      font-weight:900;
      color: var(--theme-link);
      white-space:nowrap;
    }

    .page-nt-portal .is-soon{
      opacity:0.6;
      pointer-events:none;
    }
  </style>
</BaseLayout>