---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { parseCsv } from "../../../lib/csvSimple";

import fs from "node:fs";
import path from "node:path";

import { loadCallups } from "../../../lib/callups";
import { loadClubMaster } from "../../../lib/clubMaster";

import {
  getTeamCareerGA,
  getTeamEditionSubtotals,
  getTeamEventsByEdition,
} from "../../../lib/matchEvents";

import { STRONG_TEAMS } from "../../../lib/strongTeams";

type NtMasterRow = {
  team_slug: string;
  country_name_ja: string;
  // 0=非表示 / 1=歴史的強豪国 / 2=強豪に迫る実力国
  display_tier?: string;
  wc_titles?: string;
  wc_titles_all_time?: string;
};

type NtTournamentMetaRow = {
  competition: string;
  edition: string;
  team_slug: string;
  coach_ja?: string;
  result_ja?: string;
  host_ja?: string;
  comment_ja?: string;
};

// ====================
// getStaticPaths：display_tier ベース（0は生成しない）
// ====================
export async function getStaticPaths() {
  // ★ getStaticPaths 内に閉じ込めて定義（スコープ事故を確実に回避）
  const toTier = (v: any) => {
    const n = Number(String(v ?? "").trim());
    return Number.isFinite(n) ? n : 0;
  };

  const p = path.join(process.cwd(), "src", "data", "nt_master.csv");
  const text = fs.readFileSync(p, "utf-8");
  const rows = parseCsv(text);

  return rows
    .filter((r: any) => {
      const slug = String(r.team_slug ?? "").trim();
      if (!slug) return false;
      const tier = toTier(r.display_tier);
      return tier === 1 || tier === 2; // 0は生成しない
    })
    .map((r: any) => ({ params: { team: String(r.team_slug).trim() } }));
}

// ====================
// 以降：ページ側
// ====================
function readCsv(fileName: string) {
  const p = path.join(process.cwd(), "src", "data", fileName);
  const text = fs.readFileSync(p, "utf-8");
  return parseCsv(text);
}

const { team } = Astro.params;
const teamSlug = String(team ?? "").trim();

// nt_master
const ntMaster: NtMasterRow[] = readCsv("nt_master.csv").map((r: any) => ({
  team_slug: String(r.team_slug ?? "").trim(),
  country_name_ja: String(r.country_name_ja ?? "").trim(),
  display_tier: String(r.display_tier ?? "").trim(),
  wc_titles: String(r.wc_titles ?? "").trim(),
  wc_titles_all_time: String(r.wc_titles_all_time ?? "").trim(),
}));

const me = ntMaster.find((r) => r.team_slug === teamSlug);
if (!me)
  throw new Error(`nt_master.csv に team_slug=${teamSlug} が見つかりません`);

const countryJa = me.country_name_ja;
const competition = "WC";
const teamName = countryJa; // match_events の team は表示名で揃える前提

// GA（選手別/大会別）
const gaCareer = getTeamCareerGA(competition, teamName);
const gaByEdition = getTeamEditionSubtotals(competition, teamName);
const showGA = gaCareer.length > 0;

// nt_tournament_meta
const metaAll: NtTournamentMetaRow[] = readCsv("nt_tournament_meta.csv").map(
  (r: any) => ({
    competition: String(r.competition ?? "").trim(),
    edition: String(r.edition ?? "").trim(),
    team_slug: String(r.team_slug ?? "").trim(),
    coach_ja: String(r.coach_ja ?? "").trim(),
    result_ja: String(r.result_ja ?? "").trim(),
    host_ja: String(r.host_ja ?? "").trim(),
    comment_ja: String(r.comment_ja ?? "").trim(),
  }),
);

const metaWC = metaAll
  .filter((m) => m.team_slug === teamSlug)
  .filter((m) => String(m.competition).toUpperCase() === "WC");

// callups から大会年
const callups = loadCallups()
  .filter((r: any) => String(r.competition ?? "").toUpperCase() === "WC")
  .filter((r: any) => String(r.country ?? "").trim() === countryJa);

const editionsFromCallups = Array.from(
  new Set(
    callups.map((r: any) => String(r.edition ?? "").trim()).filter(Boolean),
  ),
);

// ✅ あゆみページは “降順（最新→過去）” が必然なので統一
const editions = Array.from(
  new Set([
    ...editionsFromCallups,
    ...metaWC.map((m) => String(m.edition ?? "").trim()).filter(Boolean),
  ]),
).sort((a, b) => Number(b) - Number(a));

const metaByEdition = new Map<string, NtTournamentMetaRow>();
for (const m of metaWC) {
  const ed = String(m.edition ?? "").trim();
  if (!ed) continue;
  metaByEdition.set(ed, m);
}

// 1表用：全大会まとめ（得点/アシスト）
// ✅ 表も “降順（最新→過去）” に統一（カードと揃える）
const eventsAll = editions.flatMap((ed) =>
  getTeamEventsByEdition("WC", teamName, String(ed)).map((e) => ({
    ...e,
    edition: String(ed),
  })),
);

const toNum = (v: any) => {
  const n = Number(String(v ?? "").replace(/[^\d]/g, ""));
  return Number.isFinite(n) ? n : 0;
};

eventsAll.sort((a: any, b: any) => {
  // ★大会：降順（最新→過去）
  const ed = toNum(b.edition) - toNum(a.edition);
  if (ed !== 0) return ed;

  // 同一大会内：フェーズ→分（あなたの設計のまま）
  const ra = String(a.round ?? "");
  const rb = String(b.round ?? "");
  if (ra !== rb) return ra.localeCompare(rb, "ja");

  return toNum(a.minute) - toNum(b.minute);
});

const showGAList = eventsAll.length > 0;

// ⑤ 海外/国内（暫定）
// - league_key === 'J' を国内扱い
// - その他（未解決含む）は海外扱い
const clubMaster = loadClubMaster();
const normalize = (s: string) =>
  String(s || "")
    .trim()
    .replace(/\s+/g, " ")
    .replace(/　/g, " ")
    .toLowerCase();

const parseAliases = (aliases: string) =>
  String(aliases || "")
    .split(/[|,、/]/)
    .map((s) => s.trim())
    .filter(Boolean);

function resolveClub(clubName: string) {
  const raw = String(clubName || "").trim();
  if (!raw) return null;
  const key = normalize(raw);

  const c = clubMaster.find((x: any) => {
    const ja = normalize(x.club_display_ja || "");
    const en = normalize(x.club_display_en || "");
    if (key === ja || key === en) return true;
    const als = parseAliases(x.aliases);
    return als.some((a) => normalize(a) === key);
  });

  return c ?? null;
}

function buildOverseasSummary(edition: string) {
  const rows = callups.filter(
    (r: any) => String(r.edition ?? "").trim() === edition,
  );

  let domestic = 0;
  let total = 0;
  const seen = new Set<string>();

  for (const r of rows) {
    const key = String(r.name_en ?? "").trim();
    if (!key || seen.has(key)) continue;
    seen.add(key);

    const club = String(r.current_club ?? "").trim();
    if (!club) continue;

    const hit: any = resolveClub(club);

    // 国内クラブのみカウント（暫定：J）
    if (hit && String(hit.league_key ?? "") === "J") {
      domestic++;
    }
    total++;
  }

  const overseas = total - domestic;
  return { overseas, domestic, total };
}

const heading = `${countryJa}代表 ワールドカップの歩み`;
const title = `${countryJa}代表 W杯のあゆみ（歴代代表メンバー）`;
const description = `${countryJa}代表のワールドカップ出場史を大会別に一覧化。各大会の成績・監督・招集メンバー（スカッド）へすぐ移動できます。`;
---

<BaseLayout
  title={title}
  description={description}
  bodyClass="page-wc page-nt-hub"
  bodyStyle="margin:0; font-family: system-ui;"
  showPageHeader={true}
  crumbs={[
    { label: "トップ", href: "/" },
    { label: `${countryJa}代表`, href: "/#jp" },
    { label: "ワールドカップの歩み" },
  ]}
  heading={heading}
>
  <div class="section-wrap">
    <div class="backline">
      <a class="back" href="/nt/wc/legends">← 強豪国一覧に戻る</a>
    </div>

    <div class="strong-pills">
      {
        ntMaster
          .filter((r) => Number(String(r.display_tier ?? "").trim()) === 1)
          .map((r) => {
            const label = r.country_name_ja || r.team_slug;
            const href = `/nt/${encodeURIComponent(r.team_slug)}/wc`;
            return (
              <a
                class={`pill ${r.team_slug === teamSlug ? "is-active" : ""}`}
                href={href}
              >
                {label}
              </a>
            );
          })
      }
    </div>

    <div class="strong-pills" style="margin-top:8px;">
      {
        ntMaster
          .filter((r) => Number(String(r.display_tier ?? "").trim()) === 2)
          .map((r) => {
            const label = r.country_name_ja || r.team_slug;
            const href = `/nt/${encodeURIComponent(r.team_slug)}/wc`;
            return (
              <a
                class={`pill pill-sub ${r.team_slug === teamSlug ? "is-active" : ""}`}
                href={href}
              >
                {label}
              </a>
            );
          })
      }
    </div>

    <div class="lead">
      <p>
        {countryJa}
        代表のワールドカップ出場大会を一覧でまとめました。各大会のカードから、歴代メンバー一覧へすぐ移動できます。
      </p>
    </div>

    <section class="cards" aria-label="大会一覧">
      {
        editions.map((ed) => {
          const m = metaByEdition.get(ed);
          const coach = String(m?.coach_ja ?? "").trim();
          const result = String(m?.result_ja ?? "").trim();
          const host = String(m?.host_ja ?? "").trim();
          const comment = String(m?.comment_ja ?? "").trim();

          const summary = buildOverseasSummary(ed);
          const hasRoster = summary.total > 0;

          const href = `/wc/${ed}/team/${encodeURIComponent(countryJa)}`;

          return (
            <a class={`card ${!hasRoster ? "is-empty" : ""}`} href={href}>
              <div class="card-top">
                <div class="ed">
                  <span class="ed-year">{ed}</span>
                  <span class="ed-badge">WC</span>
                </div>
                {host && <div class="host">{host}</div>}
              </div>

              <div class="meta">
                <div class="row">
                  <span class="k">監督</span>
                  <span class="v">{coach || "—"}</span>
                </div>
                <div class="row">
                  <span class="k">成績</span>
                  <span class="v">{result || "—"}</span>
                </div>
              </div>

              <div class="stats">
                {hasRoster && teamSlug === "japan" && (
                  <div class="chip">
                    <span class="k">海外/国内</span>
                    <span class="v">
                      {summary.overseas}/{summary.domestic}
                    </span>
                  </div>
                )}
              </div>

              <div class="bottomline">
                <div class="note">
                  <span class="note-ico" aria-hidden="true">
                    💬
                  </span>
                  <span class="note-txt">{comment || "準備中"}</span>
                </div>
                <div class="go">{hasRoster ? "メンバー →" : "準備中"}</div>
              </div>
            </a>
          );
        })
      }
    </section>

    <section class="stats-wrap">
      {
        showGAList && (
          <>
            <h2 class="sec-title">歴代大会別得点・アシスト</h2>
            <div class="block">
              <div class="table-wrap">
                <table class="tbl events-tbl">
                  <thead>
                    <tr>
                      <th class="num">大会</th>
                      <th>得点者</th>
                      <th class="round">フェーズ</th>
                      <th>vs</th>
                      <th class="num">分</th>
                      <th>アシスト</th>
                      <th>備考</th>
                    </tr>
                  </thead>
                  <tbody>
                    {eventsAll.map((e) => (
                      <tr>
                        <td class="num">{e.edition}</td>
                        <td>{e.player || "—"}</td>
                        <td class="round">
                          {String(e.round ?? "").trim() || "—"}
                        </td>
                        <td>{e.vs || "—"}</td>
                        <td class="num">{e.minute ?? "—"}</td>
                        <td>{e.assist || "—"}</td>
                        <td>{e.note || ""}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </>
        )
      }

      {
        showGA && (
          <>
            <h2 class="sec-title">歴代得点・アシスト（W杯通算）</h2>

            <div class="block">
              <div class="ga-grid">
                <div class="ga-box">
                  <h3 class="ga-h">大会別（中計）</h3>
                  <div class="table-wrap ga-wrap">
                    <table class="tbl ga-tbl ga-edition">
                      <thead>
                        <tr>
                          <th>大会</th>
                          <th class="num">得点</th>
                          <th class="num">アシスト</th>
                          <th class="num">G+A</th>
                        </tr>
                      </thead>
                      <tbody>
                        {gaByEdition.map((r) => (
                          <tr>
                            <td>{r.edition}</td>
                            <td class="num">{r.goals}</td>
                            <td class="num">{r.assists}</td>
                            <td class="num">{r.ga}</td>
                          </tr>
                        ))}
                        <tr class="total">
                          <td>通算</td>
                          <td class="num">
                            {gaByEdition.reduce((s, r) => s + r.goals, 0)}
                          </td>
                          <td class="num">
                            {gaByEdition.reduce((s, r) => s + r.assists, 0)}
                          </td>
                          <td class="num">
                            {gaByEdition.reduce((s, r) => s + r.ga, 0)}
                          </td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="ga-box">
                  <h3 class="ga-h">選手別（通算）</h3>
                  <div class="table-wrap ga-wrap">
                    <table class="tbl ga-tbl ga-player">
                      <thead>
                        <tr>
                          <th class="num">#</th>
                          <th>選手</th>
                          <th class="num">得点</th>
                          <th class="num">アシスト</th>
                          <th class="num">G+A</th>
                        </tr>
                      </thead>
                      <tbody>
                        {gaCareer.map((r, i) => (
                          <tr>
                            <td class="num">{i + 1}</td>
                            <td>{r.player}</td>
                            <td class="num">{r.goals}</td>
                            <td class="num">{r.assists}</td>
                            <td class="num">{r.ga}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>

              <p class="muted ga-note">※他強豪国Verもデータ準備中</p>
            </div>
          </>
        )
      }
    </section>

    <style is:global>
      /* =========================
      Layout (page-nt-hub)
    ========================= */
      .page-nt-hub .section-wrap {
        max-width: 1100px;
        margin: 0 auto;
      }

      .page-nt-hub .lead {
        margin: 6px 0 14px;
        color: #374151;
        font-size: 14px;
        line-height: 1.7;
      }

      /* =========================
      Strong pills
    ========================= */
      .page-nt-hub .strong-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 14px;
      }

      .page-nt-hub .backline {
        margin: 4px 0 10px;
      }
      .page-nt-hub .back {
        display: inline-block;
        text-decoration: none;
        font-size: 13px;
        font-weight: 800;
        color: var(--color-wc);
      }

      .page-nt-hub .pill.is-active {
        background: color-mix(in srgb, var(--color-wc) 14%, white);
        border-color: color-mix(
          in srgb,
          var(--color-wc) 30%,
          rgba(0, 0, 0, 0.08)
        );
      }

      .page-nt-hub .pill {
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: #fff;
        font-size: 13px;
        text-decoration: none;
        color: #111;
      }
      .page-nt-hub .pill:hover {
        border-color: color-mix(
          in srgb,
          var(--color-wc) 35%,
          rgba(0, 0, 0, 0.08)
        );
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
      }
      .page-nt-hub .pill.is-disabled {
        opacity: 0.45;
        cursor: not-allowed;
        pointer-events: none;
      }

      /* =========================
      Cards
    ========================= */
      .page-nt-hub .cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 24px;
        border-top: 4px solid var(--color-wc);
        padding-top: 12px;
      }
      @media (max-width: 1100px) {
        .page-nt-hub .cards {
          grid-template-columns: repeat(3, 1fr);
        }
      }
      @media (max-width: 820px) {
        .page-nt-hub .cards {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 560px) {
        .page-nt-hub .cards {
          grid-template-columns: 1fr;
        }
      }

      .page-nt-hub .card {
        display: block;
        text-decoration: none;
        color: inherit;
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: #fff;
        border-radius: 14px;
        padding: 12px 12px 10px;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
        transition:
          transform 0.08s ease,
          box-shadow 0.08s ease;
      }
      .page-nt-hub .card:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.08);
      }
      .page-nt-hub .card.is-empty {
        opacity: 0.65;
      }

      .page-nt-hub .card-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
      }
      .page-nt-hub .ed {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .page-nt-hub .ed-year {
        font-size: 18px;
        font-weight: 750;
        letter-spacing: 0.2px;
      }
      .page-nt-hub .ed-badge {
        font-size: 12px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-wc) 18%, transparent);
        color: var(--color-wc);
        border: 1px solid color-mix(in srgb, var(--color-wc) 25%, transparent);
      }
      .page-nt-hub .host {
        font-size: 12px;
        opacity: 0.75;
        white-space: nowrap;
      }

      .page-nt-hub .meta {
        display: grid;
        gap: 6px;
        margin-bottom: 10px;
      }
      .page-nt-hub .row {
        display: flex;
        gap: 10px;
        align-items: baseline;
      }
      .page-nt-hub .row .k {
        font-size: 12px;
        opacity: 0.7;
        min-width: 34px;
      }
      .page-nt-hub .row .v {
        font-size: 13px;
        font-weight: 600;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .page-nt-hub .stats {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 8px 0 10px;
      }
      .page-nt-hub .chip {
        display: inline-flex;
        gap: 6px;
        align-items: baseline;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 999px;
        padding: 4px 10px;
        background: #fafafa;
        font-size: 12px;
      }
      .page-nt-hub .chip .k {
        opacity: 0.7;
      }
      .page-nt-hub .chip .v {
        font-weight: 700;
      }

      .page-nt-hub .comment {
        font-size: 12px;
        opacity: 0.8;
        line-height: 1.5;
        margin: 6px 0 8px;
      }
      .page-nt-hub .go {
        margin-top: 6px;
        font-size: 12.5px;
        font-weight: 700;
        color: var(--color-wc);
      }

      /* ===== Card bottom line (compact) ===== */
      .page-nt-hub .bottomline {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
        margin-top: 6px;
      }

      .page-nt-hub .note {
        display: flex;
        align-items: baseline;
        gap: 6px;
        min-width: 0; /* 省略のため */
        flex: 1;
      }

      .page-nt-hub .note-ico {
        color: var(--color-wc); /* 💬だけテーマ色 */
        font-weight: 900;
        flex: 0 0 auto;
      }

      .page-nt-hub .note-txt {
        font-size: 12px;
        opacity: 0.85;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap; /* 1行固定 */
        min-width: 0;
      }

      .page-nt-hub .go {
        margin-top: 0; /* 既存を打ち消し */
        font-size: 12.5px;
        font-weight: 900;
        color: var(--color-wc);
        white-space: nowrap;
        flex: 0 0 auto;
      }

      /* スマホ圧縮（A：高さ最小） */
      @media (max-width: 560px) {
        .page-nt-hub .card {
          padding: 10px 10px 8px;
        }
        .page-nt-hub .card-top {
          margin-bottom: 8px;
        }
        .page-nt-hub .meta {
          margin-bottom: 8px;
          gap: 5px;
        }
        .page-nt-hub .stats {
          display: none; /* chipが高さの敵なので消す（A方針） */
        }
        .page-nt-hub .bottomline {
          margin-top: 6px;
        }
      }

      /* =========================
      Stats / Tables common
    ========================= */
      .page-nt-hub .stats-wrap {
        max-width: 1100px;
        margin: 24px auto;
      }

      .page-nt-hub .sec-title {
        margin: 18px 0 10px;
        font-size: 16px;
        font-weight: 850;
      }

      .page-nt-hub .block {
        background: #fff;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 14px;
        padding: 12px;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.05);
        margin-bottom: 18px;
      }

      .page-nt-hub .table-wrap {
        overflow: auto;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 12px;
        background: #fff;
      }

      .page-nt-hub .tbl {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        min-width: 720px;
      }

